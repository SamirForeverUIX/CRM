{
  "name": "backpack-crm",
  "version": "1.0.0",
  "description": "Backpack CRM - Learning Centre Management System",
  "main": "app.js",
  "scripts": {
    "start": "npm run db:prepare && node app.js",
    "dev": "npm run db:prepare && node app.js",
    "db:prepare": "prisma generate && prisma db push",
    "migrate": "node db/schema.js",
    "seed": "node db/seed.js",
    "setup-db": "npm run db:prepare && node db/seed.js",
    "test": "node --test",
    "prisma:generate": "prisma generate",
    "prisma:introspect": "prisma db pull",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
