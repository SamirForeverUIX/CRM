<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Weekly Schedule
      </h1>
    </div>

    <% if (timeSlots.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <p>No scheduled groups yet. Add groups with days and times to see the timetable.</p>
        <a href="/groups/add" class="btn btn-primary">Add Group</a>
      </div>
    <% } else { %>
      <div class="schedule-table-wrap">
        <table class="schedule-table">
          <thead>
            <tr>
              <th class="schedule-time-col">Time</th>
              <% days.forEach(day => { %>
                <th class="schedule-day-col"><%= day %></th>
              <% }) %>
            </tr>
          </thead>
          <tbody>
            <% timeSlots.forEach(time => { %>
              <tr>
                <td class="schedule-time-cell"><%= time %></td>
                <% days.forEach(day => { %>
                  <td class="schedule-cell">
                    <% const groups = (timetable[time] && timetable[time][day]) || []; %>
                    <% groups.forEach(g => { %>
                      <a href="/groups/view/<%= g.id %>" class="schedule-block">
                        <span class="schedule-block-name"><%= g.name %></span>
                        <% if (g.teacher) { %>
                          <span class="schedule-block-teacher"><%= g.teacher.firstName %> <%= g.teacher.lastName.charAt(0) %>.</span>
                        <% } %>
                        <% if (g.room) { %>
                          <span class="schedule-block-room"><%= g.room %></span>
                        <% } %>
                      </a>
                    <% }) %>
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
