<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1 style="display:flex;align-items:center;gap:12px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Settings
      </h1>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <form action="/settings" method="POST" class="form-card">
      <div class="form-group">
        <label for="centreName">Centre Name</label>
        <input type="text" id="centreName" name="centreName" required value="<%= settings.centreName %>">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="text" id="phone" name="phone" value="<%= settings.phone %>" placeholder="Centre phone number">
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" value="<%= settings.email %>" placeholder="Centre email address">
        </div>
      </div>
      <div class="form-group">
        <label for="address">Address</label>
        <textarea id="address" name="address" rows="2" placeholder="Centre address"><%= settings.address %></textarea>
      </div>
      <div class="form-group">
        <label for="currency">Currency</label>
        <select id="currency" name="currency">
          <option value="USD" <%= settings.currency === 'USD' ? 'selected' : '' %>>USD ($)</option>
          <option value="EUR" <%= settings.currency === 'EUR' ? 'selected' : '' %>>EUR</option>
          <option value="GBP" <%= settings.currency === 'GBP' ? 'selected' : '' %>>GBP</option>
          <option value="UZS" <%= settings.currency === 'UZS' ? 'selected' : '' %>>UZS</option>
          <option value="RUB" <%= settings.currency === 'RUB' ? 'selected' : '' %>>RUB</option>
        </select>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Settings</button>
      </div>
    </form>

    <!-- Rooms Section -->
    <div class="rooms-section">
      <h2>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Rooms
      </h2>
      <form action="/settings/rooms/add" method="POST" class="room-add-form">
        <input type="text" name="roomName" placeholder="Enter room name (e.g. Room 101, Lab A)" required>
        <button type="submit" class="btn btn-primary btn-small">Add Room</button>
      </form>
      <% if (settings.rooms && settings.rooms.length > 0) { %>
        <div class="room-list">
          <% settings.rooms.forEach((room, i) => { %>
            <div class="room-chip">
              <span><%= room %></span>
              <form action="/settings/rooms/delete" method="POST" style="display:inline;">
                <input type="hidden" name="roomIndex" value="<%= i %>">
                <button type="submit" title="Remove room">&times;</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="muted" style="font-size:14px;">No rooms added yet. Add rooms here to use them when creating groups.</p>
      <% } %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
