<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>Teachers <span class="page-subtitle">Quantity &mdash; <%= teachers.length %></span></h1>
      <a href="/teachers/add" class="btn btn-primary">ADD NEW</a>
    </div>

    <% if (search) { %>
      <p class="search-info">Search results for "<strong><%= search %></strong>" &mdash; <a href="/teachers">Clear</a></p>
    <% } %>

    <% if (teachers.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <p>No teachers found.</p>
        <a href="/teachers/add" class="btn btn-primary">Add your first teacher</a>
      </div>
    <% } else { %>
      <div class="teachers-grid">
        <% teachers.forEach((teacher, i) => { %>
          <a href="/teachers/view/<%= teacher.id %>" class="teacher-card">
            <span class="teacher-card-name"><%= teacher.firstName %> <%= teacher.lastName %></span>
            <span class="teacher-card-phone"><%= teacher.phone %></span>
            <span class="teacher-card-groups"><%= teacher.groupCount || 0 %> group<%= (teacher.groupCount || 0) !== 1 ? 's' : '' %></span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
