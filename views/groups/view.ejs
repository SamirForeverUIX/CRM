<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>
        <%= group.name %>
        <% if (course) { %>&nbsp;&middot;&nbsp;<span style="font-weight:400;font-size:18px;color:var(--text-secondary);"><%= course.name %></span><% } %>
        <% if (teacher) { %>&nbsp;&middot;&nbsp;<span style="font-weight:400;font-size:18px;color:var(--text-secondary);"><%= teacher.firstName %> <%= teacher.lastName %></span><% } %>
      </h1>
      <div>
        <a href="/groups/edit/<%= group.id %>" class="btn btn-primary">Edit Group</a>
        <a href="/groups" class="btn btn-secondary">Back</a>
      </div>
    </div>

    <div class="group-view-layout">
      <!-- LEFT: Info + Students -->
      <div class="group-left-panel">
        <div class="detail-card">
          <h3>Group Info</h3>
          <div class="detail-row">
            <span class="detail-label">Course</span>
            <span><%= course ? course.name : '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Teacher</span>
            <span><%= teacher ? teacher.firstName + ' ' + teacher.lastName : '--' %></span>
          </div>
          <% if (course && course.price) { %>
          <div class="detail-row">
            <span class="detail-label">Price</span>
            <span><%= (course.price || 0).toLocaleString() %> UZS</span>
          </div>
          <% } %>
          <div class="detail-row">
            <span class="detail-label">Time</span>
            <span><%= group.days && group.days.length > 0 ? group.days.join(', ') : '--' %> &middot; <%= group.startTime || '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Room</span>
            <span><%= group.room || '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Training dates</span>
            <span><%= group.startDate || '--' %></span>
          </div>
        </div>

        <div class="detail-card">
          <h3>Students <span class="count-badge" style="margin-left:6px;font-size:11px;min-width:20px;height:20px;"><%= students.length %></span></h3>
          <% if (students.length === 0) { %>
            <p class="muted" style="font-size:13px;">No students assigned yet.</p>
          <% } else { %>
            <div class="student-list-compact">
              <% students.forEach((s, i) => { %>
                <a href="/students/view/<%= s.id %>" class="student-row">
                  <span class="student-row-num"><%= i + 1 %>.</span>
                  <span class="student-row-dot"></span>
                  <div class="student-row-info">
                    <span class="student-row-name"><%= s.firstName %> <%= s.lastName %></span>
                  </div>
                  <span style="font-size:12px;color:var(--text-muted);margin-left:auto;"><%= s.phone %></span>
                </a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- RIGHT: Attendance -->
      <div class="group-right-panel">
        <div class="detail-card attendance-panel">
          <div class="attendance-header">
            <h3 style="border:none;padding:0;margin:0;">Attendance</h3>
            <% if (lessonDates.length > 0) { %>
              <div class="attendance-nav">
                <button class="att-nav-btn current">Current</button>
                <span class="att-date-range">
                  <%
                    var fd = lessonDates[0];
                    var ld = lessonDates[lessonDates.length - 1];
                    var fds = String(fd.getDate()).padStart(2,'0') + '.' + String(fd.getMonth()+1).padStart(2,'0') + '.' + String(fd.getFullYear()).slice(2);
                    var lds = String(ld.getDate()).padStart(2,'0') + '.' + String(ld.getMonth()+1).padStart(2,'0') + '.' + String(ld.getFullYear()).slice(2);
                  %>
                  <%= fds %> - <%= lds %>
                </span>
              </div>
            <% } %>
          </div>

          <% if (students.length === 0) { %>
            <p class="muted" style="font-size:13px;">Add students to track attendance.</p>
          <% } else if (lessonDates.length === 0) { %>
            <p class="muted" style="font-size:13px;">Set a course with lessons/month, start date, and days to generate lesson dates.</p>
          <% } else { %>
            <div class="attendance-table-wrap">
              <table class="attendance-table">
                <thead>
                  <tr>
                    <th class="att-student-col">Name</th>
                    <% lessonDates.forEach((d) => { %>
                      <%
                        var dd = String(d.getDate()).padStart(2, '0');
                        var mm = String(d.getMonth() + 1).padStart(2, '0');
                        var dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
                        var months = ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'];
                        var dateStr = d.getFullYear() + '-' + mm + '-' + dd;
                      %>
                      <th class="att-date-col" data-date="<%= dateStr %>">
                        <div class="att-date-header">
                          <span class="att-date-val"><%= d.getDate() %> <%= months[d.getMonth()] %></span>
                        </div>
                      </th>
                    <% }) %>
                  </tr>
                </thead>
                <tbody>
                  <% students.forEach((s, si) => { %>
                    <%
                      // Check if first lesson has attendance for this student
                      var firstDate = lessonDates[0];
                      var fdd = String(firstDate.getDate()).padStart(2,'0');
                      var fmm = String(firstDate.getMonth()+1).padStart(2,'0');
                      var firstDateStr = firstDate.getFullYear()+'-'+fmm+'-'+fdd;
                      var firstPresent = attendanceMap[firstDateStr] && attendanceMap[firstDateStr].includes(s.id);
                    %>
                    <tr>
                      <td class="att-student-cell">
                        <div class="avatar avatar-sm avatar-gradient-<%= (si % 6) + 1 %>" style="width:24px;height:24px;font-size:9px;"><%= s.firstName.charAt(0) %><%= s.lastName.charAt(0) %></div>
                        <span><%= s.firstName %> <%= s.lastName %></span>
                        <% if (attendanceMap[firstDateStr]) { %>
                          <span class="att-was-badge">Was</span>
                        <% } %>
                      </td>
                      <% lessonDates.forEach((d) => { %>
                        <%
                          var dd2 = String(d.getDate()).padStart(2,'0');
                          var mm2 = String(d.getMonth()+1).padStart(2,'0');
                          var dateStr2 = d.getFullYear()+'-'+mm2+'-'+dd2;
                          var wasPresent = attendanceMap[dateStr2] && attendanceMap[dateStr2].includes(s.id);
                          var hasRecord = attendanceMap[dateStr2] !== undefined;
                        %>
                        <td class="att-check-cell" data-date="<%= dateStr2 %>">
                          <label class="att-checkbox">
                            <input type="checkbox"
                              data-student="<%= s.id %>"
                              data-date="<%= dateStr2 %>"
                              <%= wasPresent ? 'checked' : '' %>
                              onchange="saveAttendance(this)"
                            >
                            <span class="att-mark <%= hasRecord ? (wasPresent ? 'present' : 'absent') : '' %>">
                              <% if (hasRecord && wasPresent) { %>&#10003;<% } %>
                              <% if (hasRecord && !wasPresent) { %>&#10007;<% } %>
                            </span>
                          </label>
                        </td>
                      <% }) %>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
function saveAttendance(el) {
  var date = el.dataset.date;
  var checkboxes = document.querySelectorAll('input[data-date="' + date + '"]');
  var form = document.createElement('form');
  form.method = 'POST';
  form.action = '/groups/<%= group.id %>/attendance';
  form.style.display = 'none';

  var dateInput = document.createElement('input');
  dateInput.name = 'date';
  dateInput.value = date;
  form.appendChild(dateInput);

  var count = 0;
  checkboxes.forEach(function(cb) {
    if (cb.checked) {
      var input = document.createElement('input');
      input.name = 'present';
      input.value = cb.dataset.student;
      form.appendChild(input);
      count++;
    }
  });

  if (count === 0) {
    var empty = document.createElement('input');
    empty.name = 'present';
    empty.value = '__none__';
    form.appendChild(empty);
  }

  document.body.appendChild(form);
  form.submit();
}
</script>
<%- include('../partials/footer') %>
