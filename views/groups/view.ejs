<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1 style="display:flex;align-items:center;gap:12px;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        <%= group.name %>
      </h1>
      <div>
        <a href="/groups/edit/<%= group.id %>" class="btn btn-primary">Edit Group</a>
        <a href="/groups" class="btn btn-secondary">Back to List</a>
      </div>
    </div>

    <div class="group-view-layout">
      <!-- LEFT SIDE: Group Info + Students -->
      <div class="group-left-panel">
        <div class="detail-card">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Group Info
          </h3>
          <div class="detail-row">
            <span class="detail-label">Course</span>
            <span><%= course ? course.name : '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Teacher</span>
            <span><%= teacher ? teacher.firstName + ' ' + teacher.lastName : '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Days</span>
            <span><%= group.days && group.days.length > 0 ? group.days.join(', ') : '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Time</span>
            <span><%= group.startTime || '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Room</span>
            <span><%= group.room || '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Start Date</span>
            <span><%= group.startDate || '--' %></span>
          </div>
          <% if (course) { %>
          <div class="detail-row">
            <span class="detail-label">Lessons/Month</span>
            <span><%= course.lessonsPerMonth || '--' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Lesson Duration</span>
            <span><%= course.durationMinutes ? course.durationMinutes + ' min' : '--' %></span>
          </div>
          <% } %>
        </div>

        <div class="detail-card">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Students <span class="count-badge" style="margin-left:6px;"><%= students.length %></span>
          </h3>
          <% if (students.length === 0) { %>
            <p class="muted" style="font-size:13px;">No students assigned yet.</p>
          <% } else { %>
            <div class="student-list-compact">
              <% students.forEach((s, i) => { %>
                <a href="/students/view/<%= s.id %>" class="student-row">
                  <div class="avatar avatar-sm avatar-gradient-<%= (i % 6) + 1 %>"><%= s.firstName.charAt(0) %><%= s.lastName.charAt(0) %></div>
                  <div class="student-row-info">
                    <span class="student-row-name"><%= s.firstName %> <%= s.lastName %></span>
                    <span class="student-row-phone"><%= s.phone %></span>
                  </div>
                </a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- RIGHT SIDE: Attendance -->
      <div class="group-right-panel">
        <div class="detail-card attendance-panel">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Attendance
            <% if (lessonDates.length > 0) { %>
              <span class="count-badge" style="margin-left:6px;"><%= lessonDates.length %> lessons</span>
            <% } %>
          </h3>

          <% if (students.length === 0) { %>
            <p class="muted" style="font-size:13px;">Add students to track attendance.</p>
          <% } else if (lessonDates.length === 0) { %>
            <p class="muted" style="font-size:13px;">Set a course with lessons/month, start date, and days to auto-generate lesson dates.</p>
          <% } else { %>
            <div class="attendance-table-wrap">
              <form action="/groups/<%= group.id %>/attendance" method="POST" id="attendanceForm">
                <input type="hidden" name="date" id="attendanceDate" value="">
                <table class="attendance-table">
                  <thead>
                    <tr>
                      <th class="att-student-col">Student</th>
                      <% lessonDates.forEach((d, idx) => { %>
                        <%
                          const dd = String(d.getDate()).padStart(2, '0');
                          const mm = String(d.getMonth() + 1).padStart(2, '0');
                          const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
                          const dayAbbr = dayNames[d.getDay()];
                          const dateStr = d.getFullYear() + '-' + mm + '-' + dd;
                        %>
                        <th class="att-date-col" data-date="<%= dateStr %>">
                          <div class="att-date-header">
                            <span class="att-lesson-num"><%= idx + 1 %></span>
                            <span class="att-date-day"><%= dayAbbr %></span>
                            <span class="att-date-val"><%= dd %>.<%= mm %></span>
                          </div>
                        </th>
                      <% }) %>
                    </tr>
                  </thead>
                  <tbody>
                    <% students.forEach((s, si) => { %>
                      <tr>
                        <td class="att-student-cell">
                          <div class="avatar avatar-sm avatar-gradient-<%= (si % 6) + 1 %>" style="width:26px;height:26px;font-size:10px;"><%= s.firstName.charAt(0) %><%= s.lastName.charAt(0) %></div>
                          <span><%= s.firstName %> <%= s.lastName.charAt(0) %>.</span>
                        </td>
                        <% lessonDates.forEach((d) => { %>
                          <%
                            const dd2 = String(d.getDate()).padStart(2, '0');
                            const mm2 = String(d.getMonth() + 1).padStart(2, '0');
                            const dateStr2 = d.getFullYear() + '-' + mm2 + '-' + dd2;
                            const wasPresent = attendanceMap[dateStr2] && attendanceMap[dateStr2].includes(s.id);
                            const hasRecord = attendanceMap[dateStr2] !== undefined;
                          %>
                          <td class="att-check-cell" data-date="<%= dateStr2 %>">
                            <label class="att-checkbox">
                              <input type="checkbox"
                                data-student="<%= s.id %>"
                                data-date="<%= dateStr2 %>"
                                <%= wasPresent ? 'checked' : '' %>
                                onchange="saveAttendance(this)"
                              >
                              <span class="att-mark <%= hasRecord ? (wasPresent ? 'present' : 'absent') : '' %>">
                                <% if (hasRecord) { %>
                                  <%= wasPresent ? '&#10003;' : '&#10007;' %>
                                <% } %>
                              </span>
                            </label>
                          </td>
                        <% }) %>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
function saveAttendance(el) {
  const date = el.dataset.date;
  const checkboxes = document.querySelectorAll('input[data-date="' + date + '"]');
  const presentIds = [];
  checkboxes.forEach(cb => {
    if (cb.checked) presentIds.push(cb.dataset.student);
  });

  // Build form and submit
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/groups/<%= group.id %>/attendance';
  form.style.display = 'none';

  const dateInput = document.createElement('input');
  dateInput.name = 'date';
  dateInput.value = date;
  form.appendChild(dateInput);

  presentIds.forEach(id => {
    const input = document.createElement('input');
    input.name = 'present';
    input.value = id;
    form.appendChild(input);
  });

  // If nobody is present, send empty marker
  if (presentIds.length === 0) {
    const empty = document.createElement('input');
    empty.name = 'present';
    empty.value = '__none__';
    form.appendChild(empty);
  }

  document.body.appendChild(form);
  form.submit();
}
</script>
<%- include('../partials/footer') %>
