<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <nav class="breadcrumb">
      <span class="breadcrumb-item"><a href="/">Dashboard</a></span>
      <span class="breadcrumb-item"><a href="/groups">Groups</a></span>
      <span class="breadcrumb-item active">Edit</span>
    </nav>
    <div class="page-header">
      <h1>Edit Group</h1>
      <a href="/groups" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/groups/edit/<%= group.id %>" method="POST" class="form-card">
      <div class="form-group">
        <label for="name">Group Name</label>
        <input type="text" id="name" name="name" required value="<%= group.name %>">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="courseId">Course</label>
          <select id="courseId" name="courseId">
            <option value="">-- Select Course --</option>
            <% courses.forEach(c => { %>
              <option value="<%= c.id %>" <%= group.courseId === c.id ? 'selected' : '' %>><%= c.name %><%= c.code ? ' (' + c.code + ')' : '' %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="teacherId">Teacher</label>
          <select id="teacherId" name="teacherId">
            <option value="">-- Select Teacher --</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t.id %>" <%= group.teacherId === t.id ? 'selected' : '' %>><%= t.firstName %> <%= t.lastName %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Days</label>
        <div class="checkbox-group">
          <% daysOfWeek.forEach(day => { %>
            <label>
              <input type="checkbox" name="days" value="<%= day %>" <%= group.days && group.days.includes(day) ? 'checked' : '' %>>
              <span><%= day %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="roomId">Room</label>
          <select id="roomId" name="roomId">
            <option value="">-- Select Room --</option>
            <% rooms.forEach(room => { %>
              <option value="<%= room %>" <%= group.room === room ? 'selected' : '' %>><%= room %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="startTime">Start Time</label>
          <select id="startTime" name="startTime">
            <option value="">-- Select Time --</option>
            <% timeSlots.forEach(slot => { %>
              <option value="<%= slot %>" <%= group.startTime === slot ? 'selected' : '' %>><%= slot %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="startDate">Start Date</label>
        <input type="date" id="startDate" name="startDate" value="<%= group.startDate %>">
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/groups" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
