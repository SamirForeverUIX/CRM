<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">

    <!-- Page Header -->
    <div class="gl-header">
      <div class="gl-header-left">
        <h1 class="gl-title">Groups</h1>
        <span class="gl-subtitle">Quantity &mdash; <%= groups.length %></span>
      </div>
      <button onclick="openAddGroupPanel()" class="gl-add-btn">ADD NEW</button>
    </div>

    <!-- Filter Row -->
    <div class="gl-filters">
      <div class="gl-filter-item">
        <select class="gl-filter-select" id="filterStatus">
          <option value="">Active groups</option>
          <option value="active">Active</option>
          <option value="archived">Archived</option>
        </select>
      </div>
      <div class="gl-filter-item">
        <select class="gl-filter-select" id="filterTeacher">
          <option value="">Teachers</option>
          <% teachers.forEach(t => { %>
            <option value="<%= t.id %>"><%= t.firstName %> <%= t.lastName %></option>
          <% }) %>
        </select>
      </div>
      <div class="gl-filter-item">
        <select class="gl-filter-select" id="filterCourse">
          <option value="">Courses</option>
          <% courses.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="gl-filter-item">
        <select class="gl-filter-select" id="filterDays">
          <option value="">Days</option>
          <option value="Mon">Mon</option>
          <option value="Tue">Tue</option>
          <option value="Wed">Wed</option>
          <option value="Thu">Thu</option>
          <option value="Fri">Fri</option>
          <option value="Sat">Sat</option>
          <option value="Sun">Sun</option>
        </select>
      </div>
      <div class="gl-filter-item">
        <select class="gl-filter-select" id="filterTags">
          <option value="">Tags</option>
        </select>
      </div>
      <div class="gl-filter-item">
        <input type="date" class="gl-filter-date" id="filterStartDate" placeholder="Start date">
      </div>
      <div class="gl-filter-item">
        <input type="date" class="gl-filter-date" id="filterEndDate" placeholder="End date">
      </div>
      <button class="gl-filter-clear" onclick="clearFilters()" title="Clear filters">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Action buttons -->
    <div class="gl-actions-row">
      <button class="gl-action-btn" onclick="toggleFilters()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9c.26.604.852.997 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Filters
      </button>
      <button class="gl-action-btn" onclick="toggleColumns()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Columns
      </button>
    </div>

    <% if (search) { %>
      <p class="search-info">Search results for "<strong><%= search %></strong>" &mdash; <a href="/groups">Clear</a></p>
    <% } %>

    <% if (groups.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        </div>
        <p>No groups found.</p>
        <button onclick="openAddGroupPanel()" class="btn btn-primary">Create your first group</button>
      </div>
    <% } else { %>
      <div class="gl-table-wrap">
        <table class="gl-table table-divided">
          <thead>
            <tr>
              <th class="gl-th-sortable">Group</th>
              <th class="gl-th-sortable">Course</th>
              <th class="gl-th-sortable">Teacher</th>
              <th class="gl-th-sortable">Days</th>
              <th class="gl-th-sortable">Training dates</th>
              <th class="gl-th-sortable">Week of study</th>
              <th class="gl-th-sortable">Room</th>
              <th class="gl-th-sortable">Tags</th>
              <th class="gl-th-sortable">Students</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% groups.forEach((group, i) => { %>
              <tr class="gl-row" onclick="window.location='/groups/view/<%= group.id %>'" data-group-id="<%= group.id %>" data-teacher="<%= group.teacher ? group.teacher.id : '' %>" data-course="<%= group.course ? group.course.id : '' %>" data-days="<%= (group.days || []).join(',') %>" data-start="<%= group.startDate || '' %>" data-end="<%= group.endDate || '' %>">
                <td class="gl-cell-num"><span class="gl-row-num"><%= i + 1 %>.</span> <a href="/groups/view/<%= group.id %>" class="gl-group-name"><%= group.name %></a></td>
                <td class="gl-cell-course"><%= group.course ? group.course.name : '--' %></td>
                <td class="gl-cell-teacher"><%= group.teacher ? (group.teacher.firstName + ' ' + group.teacher.lastName).toUpperCase() : '--' %></td>
                <td class="gl-cell-days" data-days="<%= (group.days || []).join(',') %>">
                  <span class="gl-days-label"><%= group.days && group.days.length > 0 ? group.days.join(', ') : '--' %></span>
                  <% if (group.startTime) { %><br><span class="gl-days-time"><%= group.startTime %></span><% } %>
                </td>
                <td class="gl-cell-dates">
                  <% if (group.startDate) { %>
                    <%
                      var sd = new Date(group.startDate);
                      var sdStr = String(sd.getDate()).padStart(2,'0') + '.' + String(sd.getMonth()+1).padStart(2,'0') + '.' + sd.getFullYear();
                      var edStr = '';
                      if (group.endDate) {
                        var ed = new Date(group.endDate);
                        edStr = String(ed.getDate()).padStart(2,'0') + '.' + String(ed.getMonth()+1).padStart(2,'0') + '.' + ed.getFullYear();
                      }
                    %>
                    <span class="gl-date-range"><%= sdStr %> &mdash;<br><%= edStr %></span>
                  <% } else { %>
                    --
                  <% } %>
                </td>
                <td class="gl-cell-weeks">
                  <span class="gl-week-info"><%= group.weekOfStudy.months %> months</span>
                  <br><span class="gl-week-sub"><%= group.weekOfStudy.weeks %> weeks</span>
                </td>
                <td class="gl-cell-room"><%= group.room ? group.room.replace('Room ', '') : '--' %></td>
                <td class="gl-cell-tags"></td>
                <td class="gl-cell-students"><span class="gl-student-count<%= group.studentCount > 5 ? ' highlight' : '' %>"><%= group.studentCount %></span></td>
                <td class="gl-cell-actions" onclick="event.stopPropagation();">
                  <button class="gl-menu-btn" onclick="toggleRowMenu(this, event)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                  </button>
                  <div class="gl-menu-dropdown">
                    <a href="/groups/view/<%= group.id %>" class="gl-menu-item">View</a>
                    <a href="/groups/edit/<%= group.id %>" class="gl-menu-item">Edit</a>
                    <form action="/groups/delete/<%= group.id %>" method="POST" class="inline-form" onsubmit="return confirm('Delete this group?')">
                      <button type="submit" class="gl-menu-item gl-menu-danger">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- ============ ADD NEW GROUP SLIDE-IN PANEL ============ -->
  <div class="gv-modal-overlay" id="addGroupPanel" style="display:none;">
    <div class="gv-modal-container">
      <div class="gv-modal-header">
        <h2>Add New Group</h2>
        <button class="gv-modal-close" onclick="closeAddGroupPanel()">&times;</button>
      </div>
      <form action="/groups/add" method="POST" class="gv-modal-form">
        <div class="gv-form-group">
          <label>Name</label>
          <input type="text" name="name" class="gv-input" required>
        </div>
        <div class="gv-form-group">
          <label>Select course</label>
          <select name="courseId" class="gv-select">
            <option value="">Select options</option>
            <% courses.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="gv-form-group">
          <label>Select teacher</label>
          <select name="teacherId" class="gv-select">
            <option value="">Select options</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t.id %>"><%= t.firstName.toUpperCase() %> <%= t.lastName.toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div class="gv-form-group">
          <label>Days</label>
          <div class="gv-days-grid">
            <% daysOfWeek.forEach(d => { %>
              <label class="gv-day-checkbox">
                <input type="checkbox" name="days" value="<%= d %>">
                <span class="gv-day-label"><%= d %></span>
              </label>
            <% }) %>
          </div>
        </div>
        <div class="gv-form-group">
          <label>Select room</label>
          <select name="roomId" class="gv-select">
            <option value="">Select options</option>
            <% rooms.forEach(room => { %>
              <option value="<%= room %>"><%= room %></option>
            <% }) %>
          </select>
        </div>
        <div class="gv-form-group">
          <label>Lesson start time</label>
          <div class="gv-time-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <input type="text" name="startTime" placeholder="No time selected" class="gv-time-input">
          </div>
        </div>
        <div class="gv-form-group">
          <label>Group start date</label>
          <div class="gv-date-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <input type="date" name="startDate" placeholder="No date selected">
          </div>
        </div>
        <button type="submit" class="gv-submit-btn">Submit</button>
      </form>
    </div>
  </div>

</main>

<script>
function openAddGroupPanel() {
  document.getElementById('addGroupPanel').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeAddGroupPanel() {
  document.getElementById('addGroupPanel').style.display = 'none';
  document.body.style.overflow = '';
}
document.addEventListener('click', function(e) {
  if (e.target.id === 'addGroupPanel') closeAddGroupPanel();
  // Close any open row menus
  if (!e.target.closest('.gl-cell-actions')) {
    document.querySelectorAll('.gl-menu-dropdown.open').forEach(function(m) {
      m.classList.remove('open');
    });
  }
});
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeAddGroupPanel();
});
function toggleRowMenu(btn, e) {
  e.stopPropagation();
  var dropdown = btn.nextElementSibling;
  var wasOpen = dropdown.classList.contains('open');
  // Close all
  document.querySelectorAll('.gl-menu-dropdown.open').forEach(function(m) {
    m.classList.remove('open');
  });
  if (!wasOpen) dropdown.classList.add('open');
}
function toggleFilters() {
  var filters = document.querySelector('.gl-filters');
  filters.classList.toggle('hidden');
}
function toggleColumns() {
  // placeholder for column visibility toggle
}
function clearFilters() {
  document.querySelectorAll('.gl-filter-select').forEach(function(s) { s.selectedIndex = 0; });
  document.querySelectorAll('.gl-filter-date').forEach(function(d) { d.value = ''; });
  applyFilters();
}
function applyFilters() {
  var teacher = document.getElementById('filterTeacher').value;
  var course = document.getElementById('filterCourse').value;
  var day = document.getElementById('filterDays').value;
  var startDate = document.getElementById('filterStartDate').value;
  var endDate = document.getElementById('filterEndDate').value;
  var rows = document.querySelectorAll('.gl-row');
  rows.forEach(function(row) {
    var show = true;
    if (teacher && row.getAttribute('data-teacher') !== teacher) show = false;
    if (course && row.getAttribute('data-course') !== course) show = false;
    if (day && !(row.getAttribute('data-days') || '').split(',').includes(day)) show = false;
    if (startDate && row.getAttribute('data-start') && row.getAttribute('data-start') < startDate) show = false;
    if (endDate && row.getAttribute('data-end') && row.getAttribute('data-end') > endDate) show = false;
    row.style.display = show ? '' : 'none';
  });
}
// Attach filter change listeners
document.querySelectorAll('.gl-filter-select, .gl-filter-date').forEach(function(el) {
  el.addEventListener('change', applyFilters);
});
</script>
<%- include('../partials/footer') %>
