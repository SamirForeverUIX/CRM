<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>Add Group</h1>
      <a href="/groups" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/groups/add" method="POST" class="form-card">
      <div class="form-group">
        <label for="name">Group Name</label>
        <input type="text" id="name" name="name" required placeholder="e.g. A1 English Morning">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="courseId">Course</label>
          <select id="courseId" name="courseId">
            <option value="">-- Select Course --</option>
            <% courses.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %><%= c.code ? ' (' + c.code + ')' : '' %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="teacherId">Teacher</label>
          <select id="teacherId" name="teacherId">
            <option value="">-- Select Teacher --</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t.id %>"><%= t.firstName %> <%= t.lastName %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Days</label>
        <div class="checkbox-group">
          <% daysOfWeek.forEach(day => { %>
            <label>
              <input type="checkbox" name="days" value="<%= day %>">
              <span><%= day %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="roomId">Room</label>
          <select id="roomId" name="roomId">
            <option value="">-- Select Room --</option>
            <% rooms.forEach(room => { %>
              <option value="<%= room %>"><%= room %></option>
            <% }) %>
          </select>
          <% if (rooms.length === 0) { %>
            <small class="muted">Add rooms in <a href="/settings" style="color:var(--primary);">Settings</a></small>
          <% } %>
        </div>
        <div class="form-group">
          <label for="startTime">Start Time</label>
          <select id="startTime" name="startTime">
            <option value="">-- Select Time --</option>
            <% timeSlots.forEach(slot => { %>
              <option value="<%= slot %>"><%= slot %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="startDate">Start Date</label>
        <input type="date" id="startDate" name="startDate">
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create Group</button>
        <a href="/groups" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
