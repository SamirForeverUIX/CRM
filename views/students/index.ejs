<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">

    <!-- Page Header -->
    <div class="sl-header">
      <div class="sl-header-left">
        <h1 class="sl-title">Students</h1>
        <span class="sl-quantity">Quantity &mdash; <strong><%= students.length %></strong></span>
      </div>
      <div class="sl-header-actions">
        <% if (showArchived) { %>
          <a href="/students<%= search || filterGroup || filterDebt ? '?' + new URLSearchParams({search, group: filterGroup, debt: filterDebt}).toString() : '' %>" class="sl-archived-toggle sl-archived-toggle--hide">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            Hide Archived
          </a>
        <% } else { %>
          <a href="/students?archived=1<%= search ? '&search=' + encodeURIComponent(search) : '' %><%= filterGroup ? '&group=' + filterGroup : '' %><%= filterDebt ? '&debt=' + filterDebt : '' %>" class="sl-archived-toggle">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
            Show Archived
          </a>
        <% } %>
        <button onclick="openAddStudentPanel()" class="sl-add-btn">ADD NEW</button>
      </div>
    </div>

    <!-- Filter Bar -->
    <form action="/students" method="GET" class="sl-filters">
      <% if (showArchived) { %><input type="hidden" name="archived" value="1"><% } %>
      <div class="sl-filter-row">
        <input type="text" name="search" placeholder="Search by name or phone" value="<%= search %>" class="sl-filter-input">
        <select name="course" class="sl-filter-select">
          <option value="">By Courses</option>
          <% courses.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
        <select name="status" class="sl-filter-select">
          <option value="">Status</option>
          <option value="active">Active</option>
          <option value="inactive">Frozen</option>
          <option value="archived">Archived</option>
        </select>
        <select name="debt" class="sl-filter-select">
          <option value="">Financial situation</option>
          <option value="unpaid" <%= filterDebt === 'unpaid' ? 'selected' : '' %>>Has debt</option>
          <option value="paid" <%= filterDebt === 'paid' ? 'selected' : '' %>>Fully paid</option>
        </select>
        <select name="group" class="sl-filter-select">
          <option value="">By Groups</option>
          <% groups.forEach(g => { %>
            <option value="<%= g.id %>" <%= filterGroup === g.id ? 'selected' : '' %>><%= g.name %></option>
          <% }) %>
        </select>
        <input type="date" name="startDate" class="sl-filter-date" placeholder="Start date">
        <input type="date" name="endDate" class="sl-filter-date" placeholder="End date">
      </div>
      <div class="sl-filter-actions">
        <button type="submit" class="sl-filter-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9c.26.604.852.997 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Filters
        </button>
        <button type="button" class="sl-filter-btn" onclick="toggleColumns()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Columns
        </button>
        <% if (search || filterGroup || filterDebt) { %>
          <a href="/students" class="sl-filter-btn sl-filter-clear">Clear</a>
        <% } %>
      </div>
    </form>

    <!-- Students Table -->
    <% if (students.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <p>No students found.</p>
        <button onclick="openAddStudentPanel()" class="btn btn-primary">Add your first student</button>
      </div>
    <% } else { %>
      <div class="sl-table-wrap">
        <table class="sl-table">
          <thead>
            <tr>
              <th class="sl-th-num"></th>
              <th class="sl-th-photo">Photo</th>
              <th class="sl-th-name">Name</th>
              <th class="sl-th-phone">Phone</th>
              <th class="sl-th-groups">Groups</th>
              <th class="sl-th-teacher">Teachers</th>
              <th class="sl-th-dates">Training dates</th>
              <th class="sl-th-balance">Balance</th>
              <th class="sl-th-actions"></th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(function(student, i) { %>
              <tr class="sl-row <%= student.status === 'archived' ? 'sl-row--archived' : student.status === 'inactive' ? 'sl-row--frozen' : '' %>" onclick="window.location='/students/view/<%= student.id %>'" style="cursor:pointer;">
                <td class="sl-cell-num"><%= i + 1 %>.</td>
                <td class="sl-cell-photo">
                  <div class="sl-photo-placeholder">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                </td>
                <td class="sl-cell-name"><%= student.firstName %> <%= student.lastName %></td>
                <td class="sl-cell-phone"><%= student.phone %></td>
                <td class="sl-cell-groups">
                  <% if (student.groupInfo && student.groupInfo.length > 0) { %>
                    <% student.groupInfo.forEach(function(gi) { %>
                      <div class="sl-group-entry">
                        <% if (gi.courseCode) { %>
                          <span class="sl-course-badge"><%= gi.courseCode %></span>
                        <% } %>
                        <span class="sl-group-name"><%= gi.name %><% if (gi.startTime) { %> (<%= gi.startTime %>)<% } %></span>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <span class="sl-muted">&mdash;</span>
                  <% } %>
                </td>
                <td class="sl-cell-teacher"><%= student.teacherName || '&mdash;' %></td>
                <td class="sl-cell-dates">
                  <% if (student.trainingStart) { %>
                    <span class="sl-date-range">
                      <%= student.trainingStart %> &mdash;
                      <% if (student.trainingEnd) { %>
                        <br><%= student.trainingEnd %>
                      <% } %>
                    </span>
                  <% } else { %>
                    <span class="sl-muted">&mdash;</span>
                  <% } %>
                </td>
                <td class="sl-cell-balance">
                  <% var bal = student.balance || 0; %>
                  <span class="sl-balance <%= bal < 0 ? 'negative' : bal > 0 ? 'positive' : '' %>">
                    <%= bal.toLocaleString() %>
                  </span>
                </td>
                <td class="sl-cell-actions" onclick="event.stopPropagation();">
                  <div class="sl-menu-wrapper">
                    <button class="sl-dots-btn" onclick="this.parentElement.classList.toggle('open');">
                      <svg width="4" height="16" viewBox="0 0 4 16" fill="currentColor"><circle cx="2" cy="2" r="1.5"/><circle cx="2" cy="8" r="1.5"/><circle cx="2" cy="14" r="1.5"/></svg>
                    </button>
                    <div class="sl-dropdown">
                      <a href="/students/view/<%= student.id %>" class="sl-dropdown-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        View
                      </a>
                      <% if (student.status === 'archived') { %>
                        <button class="sl-dropdown-item sl-dropdown-success" onclick="studentAction(event, '/students/restore/<%= student.id %>', 'restore', '<%= student.firstName %> <%= student.lastName %>')">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.88"/></svg>
                          Restore
                        </button>
                        <button class="sl-dropdown-item sl-dropdown-danger" onclick="studentAction(event, '/students/hard-delete/<%= student.id %>', 'delete', '<%= student.firstName %> <%= student.lastName %>')">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                          Delete Permanently
                        </button>
                      <% } else { %>
                        <a href="/students/edit/<%= student.id %>" class="sl-dropdown-item">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.83 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
                          Edit
                        </a>
                        <% if (student.status === 'inactive') { %>
                          <button class="sl-dropdown-item" onclick="studentAction(event, '/students/unfreeze/<%= student.id %>', 'unfreeze', '<%= student.firstName %> <%= student.lastName %>')">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07"/></svg>
                            Unfreeze
                          </button>
                        <% } else { %>
                          <button class="sl-dropdown-item" onclick="studentAction(event, '/students/freeze/<%= student.id %>', 'freeze', '<%= student.firstName %> <%= student.lastName %>')">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07"/></svg>
                            Freeze
                          </button>
                        <% } %>
                        <button class="sl-dropdown-item sl-dropdown-danger" onclick="studentAction(event, '/students/delete/<%= student.id %>', 'archive', '<%= student.firstName %> <%= student.lastName %>')">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
                          Archive
                        </button>
                      <% } %>
                    </div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

  </div>

  <!-- ============ ADD NEW STUDENT SLIDE-IN PANEL ============ -->
  <div class="gv-modal-overlay" id="addStudentPanel" style="display:none;">
    <div class="gv-modal-container">
      <div class="gv-modal-header">
        <h2>Add New Student</h2>
        <button class="gv-modal-close" onclick="closeAddStudentPanel()">&times;</button>
      </div>
      <form action="/students/add" method="POST" class="gv-modal-form">
        <div class="gv-form-group">
          <label>First Name</label>
          <input type="text" name="firstName" class="gv-input" required placeholder="Enter first name">
        </div>
        <div class="gv-form-group">
          <label>Last Name</label>
          <input type="text" name="lastName" class="gv-input" required placeholder="Enter last name">
        </div>
        <div class="gv-form-group">
          <label>Phone Number</label>
          <input type="text" name="phone" class="gv-input" required placeholder="Enter phone number">
        </div>
        <div class="gv-form-group">
          <label>Assign to Group</label>
          <% if (groups.length === 0) { %>
            <p style="font-size:13px; color:var(--text-muted);">No groups available.</p>
          <% } else { %>
            <select name="groupIds" class="gv-select">
              <option value="">-- Select Group --</option>
              <% groups.forEach(g => { %>
                <option value="<%= g.id %>"><%= g.name %></option>
              <% }) %>
            </select>
          <% } %>
        </div>
        <button type="submit" class="gv-submit-btn">Add Student</button>
      </form>
    </div>
  </div>

</main>

<script>
function openAddStudentPanel() {
  document.getElementById('addStudentPanel').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeAddStudentPanel() {
  document.getElementById('addStudentPanel').style.display = 'none';
  document.body.style.overflow = '';
}
document.addEventListener('click', function(e) {
  if (e.target.id === 'addStudentPanel') closeAddStudentPanel();
  // Close all dropdowns on outside click
  if (!e.target.closest('.sl-menu-wrapper')) {
    document.querySelectorAll('.sl-menu-wrapper.open').forEach(function(m) { m.classList.remove('open'); });
  }
});
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeAddStudentPanel();
});

function studentAction(e, url, type, name) {
  e.stopPropagation();
  var labels = {
    archive: 'Archive "' + name + '"? They will be hidden from the main list.',
    delete: 'Permanently delete "' + name + '"? This cannot be undone.',
    restore: 'Restore "' + name + '" to active?',
    freeze: 'Freeze "' + name + '"? Their status will become inactive.',
    unfreeze: 'Unfreeze "' + name + '"?'
  };
  if (!confirm(labels[type] || 'Are you sure?')) return;
  var row = e.target.closest('tr');
  fetch(url, {
    method: 'POST',
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) {
      if (type === 'delete' || type === 'archive') {
        if (row) row.remove();
      } else if (type === 'restore') {
        if (row) row.remove();
      } else {
        // freeze/unfreeze: reload to reflect new status
        window.location.reload();
      }
    }
  }).catch(function() { window.location.reload(); });
}
</script>
<%- include('../partials/footer') %>
