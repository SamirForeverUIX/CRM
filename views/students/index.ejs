<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>Students <span class="page-subtitle">Quantity &mdash; <%= students.length %></span></h1>
      <a href="/students/add" class="btn btn-primary">ADD NEW</a>
    </div>

    <div class="filter-bar">
      <form action="/students" method="GET" class="filter-form">
        <input type="text" name="search" placeholder="Search by name or phone" value="<%= search %>">
        <select name="group">
          <option value="">All Groups</option>
          <% groups.forEach(g => { %>
            <option value="<%= g.id %>" <%= filterGroup === g.id ? 'selected' : '' %>><%= g.name %></option>
          <% }) %>
        </select>
        <select name="debt">
          <option value="">Financial situation</option>
          <option value="unpaid" <%= filterDebt === 'unpaid' ? 'selected' : '' %>>Has debt</option>
          <option value="paid" <%= filterDebt === 'paid' ? 'selected' : '' %>>Fully paid</option>
        </select>
        <button type="submit" class="btn btn-primary btn-small">Filter</button>
        <a href="/students" class="btn btn-secondary btn-small">Clear</a>
      </form>
    </div>

    <% if (students.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        </div>
        <p>No students found.</p>
        <a href="/students/add" class="btn btn-primary">Add your first student</a>
      </div>
    <% } else { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Phone</th>
            <th>Groups</th>
            <th>Teacher</th>
            <th>Training dates</th>
            <th>Balance</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach((student, i) => { %>
            <tr>
              <td style="color:var(--text-muted);"><%= i + 1 %>.</td>
              <td>
                <a href="/students/view/<%= student.id %>" class="table-link" style="display:flex;align-items:center;gap:10px;">
                  <div class="avatar avatar-sm avatar-gradient-<%= (i % 6) + 1 %>" style="width:28px;height:28px;font-size:10px;"><%= student.firstName.charAt(0) %><%= student.lastName.charAt(0) %></div>
                  <%= student.firstName %> <%= student.lastName %>
                </a>
              </td>
              <td style="color:var(--primary);font-weight:500;"><%= student.phone %></td>
              <td>
                <% if (student.groupNames.length > 0) { %>
                  <% student.groupNames.forEach(function(name, gi) { %>
                    <span class="group-code-badge"><%= name %></span>
                  <% }) %>
                <% } else { %>
                  <span class="muted">--</span>
                <% } %>
              </td>
              <td style="font-size:13px;"><%= student.teacherName || '--' %></td>
              <td style="font-size:12px;color:var(--text-secondary);"><%= student.trainingDates || '--' %></td>
              <td>
                <% var bal = student.balance || 0; %>
                <span class="balance-text <%= bal < 0 ? 'negative' : bal > 0 ? 'positive' : '' %>">
                  <%= bal < 0 ? '' : '' %><%= bal.toLocaleString() %>
                </span>
              </td>
              <td class="actions-cell">
                <a href="/students/view/<%= student.id %>" class="btn btn-small btn-secondary">View</a>
                <a href="/students/edit/<%= student.id %>" class="btn btn-small btn-edit">Edit</a>
                <form action="/students/delete/<%= student.id %>" method="POST" class="inline-form" onsubmit="return confirm('Delete?')">
                  <button type="submit" class="btn btn-small btn-delete">Del</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
