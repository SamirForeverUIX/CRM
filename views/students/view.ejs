<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>Student Profile</h1>
      <div>
        <a href="/students/edit/<%= student.id %>" class="btn btn-primary">Edit</a>
        <a href="/students" class="btn btn-secondary">Back</a>
      </div>
    </div>

    <% const payments = student.payments || []; %>

    <div class="student-view-layout">
      <!-- LEFT: Profile Card -->
      <div class="student-profile-panel">
        <div class="student-profile-card">
          <div class="student-profile-avatar avatar-gradient-1">
            <%= student.firstName.charAt(0) %><%= student.lastName.charAt(0) %>
          </div>
          <div class="student-profile-name"><%= student.firstName %> <%= student.lastName %></div>
          <div class="student-profile-info">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:<%= student.phone %>" style="color:var(--primary);font-weight:500;"><%= student.phone %></a>
          </div>

          <div class="student-balance-badge <%= balance < 0 ? 'negative' : balance > 0 ? 'positive' : 'zero' %>">
            <span class="student-balance-label">Balance</span>
            <span class="student-balance-amount"><%= balance.toLocaleString() %></span>
          </div>

          <div class="student-profile-groups">
            <div style="font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:8px;">Groups</div>
            <% if (studentGroups.length > 0) { %>
              <% studentGroups.forEach(g => { %>
                <a href="/groups/view/<%= g.id %>" class="group-code-badge" style="margin:2px;"><%= g.name %></a>
              <% }) %>
            <% } else { %>
              <span class="muted" style="font-size:13px;">Not assigned</span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- RIGHT: Payments -->
      <div class="student-payments-panel">
        <!-- Monthly balance row -->
        <div class="monthly-balance-row">
          <div class="monthly-balance-item">
            <span class="monthly-balance-label">Total Paid</span>
            <span class="monthly-balance-value positive"><%= totalPaid.toLocaleString() %></span>
          </div>
          <div class="monthly-balance-item">
            <span class="monthly-balance-label">Total Owed</span>
            <span class="monthly-balance-value negative"><%= totalOwed.toLocaleString() %></span>
          </div>
          <div class="monthly-balance-item">
            <span class="monthly-balance-label">Balance</span>
            <span class="monthly-balance-value <%= balance < 0 ? 'negative' : 'positive' %>"><%= balance.toLocaleString() %></span>
          </div>
        </div>

        <!-- Payment Form -->
        <div class="section-block">
          <h2>Add Payment</h2>
          <form action="/students/payment/<%= student.id %>" method="POST" class="payment-form">
            <input type="number" name="amount" step="0.01" min="0" placeholder="Amount" required>
            <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>">
            <select name="status">
              <option value="paid">Paid</option>
              <option value="partial">Partial</option>
              <option value="unpaid">Unpaid</option>
            </select>
            <button type="submit" class="btn btn-primary btn-small">Add</button>
          </form>
        </div>

        <!-- Payment History -->
        <div class="section-block">
          <h2>Payment History</h2>
          <% if (payments.length === 0) { %>
            <p class="muted" style="font-size:13px;">No payments recorded yet.</p>
          <% } else { %>
            <table class="data-table payment-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Date</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% payments.forEach((p, i) => { %>
                  <tr>
                    <td style="color:var(--text-muted);"><%= i + 1 %>.</td>
                    <td><%= p.date %></td>
                    <td style="font-weight:600;"><%= (p.amount || 0).toLocaleString() %></td>
                    <td>
                      <span class="status-badge status-<%= p.status %>"><%= p.status %></span>
                    </td>
                    <td>
                      <form action="/students/payment/<%= student.id %>/delete/<%= p.id %>" method="POST" class="inline-form" onsubmit="return confirm('Delete?')">
                        <button type="submit" class="btn btn-small btn-delete">Del</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
