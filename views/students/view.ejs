<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <nav class="breadcrumb">
      <span class="breadcrumb-item"><a href="/">Dashboard</a></span>
      <span class="breadcrumb-item"><a href="/students">Students</a></span>
      <span class="breadcrumb-item active"><%= student.firstName %> <%= student.lastName %></span>
    </nav>

    <% const payments = (student.payments || []).slice().reverse(); %>

    <div class="sv-layout">
      <!-- ============ LEFT: Profile Card ============ -->
      <div class="sv-left">
        <div class="sv-profile-card">
          <!-- Avatar + Action Icons Row -->
          <div class="sv-profile-top">
            <div class="sv-avatar">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
            <div class="sv-action-icons">
              <button type="button" class="sv-action-icon sv-icon-edit" title="Edit" onclick="openEditModal()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.83 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
              </button>
              <form action="/students/delete/<%= student.id %>" method="POST" class="inline-form" onsubmit="return showDeleteModal(event, '<%= (student.firstName + ' ' + student.lastName).replace(/'/g, "\\'") %>')">
                <button type="submit" class="sv-action-icon sv-icon-delete" title="Delete">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </form>
            </div>
          </div>

          <!-- Name & ID -->
          <div class="sv-name" id="svStudentName"><%= student.firstName %> <%= student.lastName %></div>
          <div class="sv-id">(id: <%= student.id.substring(0, 7) %>)</div>

          <!-- Balance Badge -->
          <div class="sv-balance-row">
            <span class="sv-balance-pill <%= balance < 0 ? 'negative' : balance > 0 ? 'positive' : 'zero' %>" id="svStudentBalance">
              <%= balance.toLocaleString() %> <%= currency %>
            </span>
            <span class="sv-balance-label">balance</span>
          </div>

          <div class="sv-divider"></div>

          <!-- Phone -->
          <div class="sv-info-section">
            <div class="sv-info-label">Phone:</div>
            <a href="tel:<%= student.phone %>" class="sv-phone-link" id="svStudentPhone"><%= student.phone %></a>
          </div>

          <div class="sv-info-section" style="margin-top: 12px;">
            <span class="sv-info-label" style="display:inline;">Status:</span>
            <span class="sv-info-value" style="margin-left: 6px;" id="svStudentStatus"><%= (student.status || 'active').toUpperCase() %></span>
          </div>

          <!-- Birthday -->
          <% if (student.birthday) { %>
          <div class="sv-info-section sv-birthday-row">
            <span class="sv-info-label">Birthday:</span>
            <span class="sv-info-value">
              <% const bd = new Date(student.birthday); %>
              <%= String(bd.getDate()).padStart(2,'0') %>.<%= String(bd.getMonth()+1).padStart(2,'0') %>.<%= bd.getFullYear() %>
            </span>
          </div>
          <% } %>

          <div class="sv-divider"></div>

          <!-- Added Date -->
          <div class="sv-info-section">
            <span class="sv-info-label">Added at:</span>
            <span class="sv-info-value"><%= student.createdAt ? new Date(student.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) : 'Unknown' %></span>
          </div>

          <div class="sv-divider"></div>

          <!-- Action Buttons -->
          <div class="sv-card-actions">
            <button type="button" class="sv-btn-outline sv-btn-teal" onclick="openAddToGroupModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
              Add to group
            </button>
            <div style="flex:1;"></div>
            <div class="sv-payment-btn-wrap">
              <a href="#payment-section" class="sv-btn-outline sv-btn-teal sv-btn-payment-main">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                Add payment
              </a>
            </div>
          </div>

          <!-- Note Section -->
          <div class="sv-note-section">
            <div class="sv-note-bar"></div>
            <div class="sv-note-content">
                <span class="sv-note-placeholder" id="svStudentNote"><%= student.notes || 'Note' %></span>
            </div>
            <div class="sv-note-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ RIGHT: Groups, Balance, Payments ============ -->
      <div class="sv-right">

        <!-- Tabs -->
        <div class="sv-tabs">
          <button class="sv-tab active" data-stab="groups">Groups</button>
          <button class="sv-tab" data-stab="comments">Comments</button>
          <button class="sv-tab" data-stab="callhistory">Call history</button>
          <button class="sv-tab" data-stab="sms">SMS</button>
          <button class="sv-tab" data-stab="history">History</button>
          <button class="sv-tab" data-stab="leadhistory">Lead history</button>
        </div>

        <!-- Group Cards -->
        <div class="sv-stab-content active" id="stab-groups">
        <div id="studentGroupsSection">
        <% if (studentGroups.length > 0) { %>
          <div class="sv-groups-row">
          <% studentGroups.forEach(function(g) { %>
            <div class="sv-group-card">
              <div class="sv-group-main">
                <div class="sv-group-top-row">
                  <div class="sv-group-left-info">
                    <span class="sv-group-code-badge"><%= g.courseCode || g.name %></span>
                    <div class="sv-group-name"><%= g.name %></div>
                    <div class="sv-group-teacher"><%= g.teacherName %></div>
                  </div>
                  <div class="sv-group-right-info">
                    <div class="sv-group-dates">
                      <%= g.startDate || '' %> &mdash;
                      <br><%= g.endDate || '' %>
                    </div>
                    <div class="sv-group-schedule">
                      <% if (g.schedule) { %><%= g.schedule %><% } else { %>Other<% } %>
                      <% if (g.scheduleTime) { %> &bull; <%= g.scheduleTime %><% } %>
                    </div>
                  </div>
                </div>

                <div class="sv-group-divider"></div>

                <div class="sv-group-details">
                  <div class="sv-group-detail-row">
                    <span class="sv-detail-label">Status:</span>
                    <span class="sv-detail-value"><strong>Active (Learns)</strong></span>
                  </div>
                  <% if (g.startDate) { %>
                  <div class="sv-group-detail-row">
                    <span class="sv-detail-label">Added at:</span>
                    <span class="sv-detail-value"><strong><%= g.startDate %></strong></span>
                  </div>
                  <div class="sv-group-detail-row">
                    <span class="sv-detail-label">Activated at:</span>
                    <span class="sv-detail-value"><strong><%= g.startDate %></strong></span>
                  </div>
                  <% } %>
                  <div class="sv-group-detail-row">
                    <span class="sv-detail-label">Price for student:</span>
                    <span class="sv-detail-value"><strong><%= g.coursePrice ? g.coursePrice.toLocaleString() + ' ' + currency : 'N/A' %></strong></span>
                  </div>
                  <div class="sv-group-detail-row">
                    <span class="sv-detail-label">By group:</span>
                    <span class="sv-detail-value">
                      <a href="/groups/view/<%= g.id %>" class="sv-group-link-icon" title="View group">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                      </a>
                      <span class="sv-group-hash">#</span> /
                    </span>
                  </div>
                </div>
              </div>

              <div class="sv-group-actions">
                <form action="/students/remove-from-group/<%= student.id %>" method="POST" class="inline-form" onsubmit="return showDeleteModal(event, 'student from this group (will be archived)')">
                  <input type="hidden" name="groupId" value="<%= g.id %>">
                  <button type="submit" class="sv-group-action-btn sv-icon-remove" title="Remove from group and archive">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
          </div>
        <% } else { %>
          <div class="sv-empty-groups">
            <p class="muted">No groups assigned. <a href="#" onclick="openAddToGroupModal(); return false;" style="color:var(--primary);">Add to a group</a></p>
          </div>
        <% } %>
        </div>

        <div class="sv-section-header">
          <h2>Attendance summary</h2>
        </div>
        <div id="studentAttendanceSection" class="sv-attendance-summary">
          <div class="skeleton skeleton-text" style="height:18px;width:40%;margin-bottom:8px;"></div>
          <div class="skeleton skeleton-text" style="height:14px;width:100%;"></div>
          <div class="skeleton skeleton-text" style="height:14px;width:85%;"></div>
        </div>

        <div id="studentFinanceSection">

        <!-- Monthly Balance Status -->
        <div class="sv-section-header">
          <h2>Monthly balance status</h2>
          <button class="sv-calendar-btn" title="Calendar view">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </button>
        </div>

        <div class="sv-monthly-scroll-wrap">
          <button class="sv-scroll-arrow sv-scroll-left" onclick="scrollMonthly(-1)">&lsaquo;</button>
          <div class="sv-monthly-cards">
            <%
              // Generate monthly balance cards (8 months for scroll)
              const now = new Date();
              const months = [];
              for (let i = 0; i < 8; i++) {
                const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
                const yr = d.getFullYear();
                const mo = String(d.getMonth() + 1).padStart(2, '0');
                const label = yr + ' M' + mo;

                const monthKey = yr + '-' + mo;

                // Sum charges for this month
                let monthlyOwed = 0;
                (charges || []).forEach(function(c) {
                  if (c.month === monthKey) monthlyOwed += c.amount;
                });

                // Sum payments for this month
                let monthlyPaid = 0;
                (student.payments || []).forEach(function(p) {
                  if (p.date) {
                    const pd = new Date(p.date);
                    if (pd.getFullYear() === yr && pd.getMonth() === d.getMonth()) {
                      if (p.status === 'paid' || p.status === 'partial') monthlyPaid += p.amount || 0;
                    }
                  }
                });

                const chargesThisMonth = (charges || []).filter(function(c) { return c.month === monthKey; });
                months.push({ label: label, chargeCount: chargesThisMonth.length, balance: monthlyPaid - monthlyOwed });
              }
            %>
            <% months.forEach(function(m) { %>
              <div class="sv-month-card <%= m.balance < 0 ? 'negative' : m.balance > 0 ? 'positive' : '' %>">
                <div class="sv-month-label"><%= m.label %><% if (m.chargeCount > 0) { %> <span title="<%= m.chargeCount %> charge(s)"><%= m.chargeCount %></span><% } %></div>
                <div class="sv-month-amount"><%= m.balance.toLocaleString() %></div>
              </div>
            <% }) %>
          </div>
          <button class="sv-scroll-arrow sv-scroll-right" onclick="scrollMonthly(1)">&rsaquo;</button>
        </div>

        <!-- Charges Section -->
        <div class="sv-section-header">
          <h2>Charges</h2>
        </div>
        <div class="sv-payment-form-wrap">
          <form action="/students/charge/<%= student.id %>" method="POST" class="sv-payment-form sv-charge-form">
            <input type="month" name="month" value="<%= new Date().toISOString().slice(0, 7) %>">
            <select name="groupId">
              <option value="">Select group</option>
              <% studentGroups.forEach(function(g) { %>
                <option value="<%= g.id %>"><%= g.name %></option>
              <% }) %>
            </select>
            <input type="number" name="amount" step="0.01" min="0" placeholder="Amount" required>
            <input type="text" name="description" placeholder="Description">
            <button type="submit" class="sv-btn-outline sv-btn-teal">Add Charge</button>
          </form>
        </div>

        <% if (charges.length > 0) { %>
          <div class="sv-payments-table-wrap">
            <table class="sv-payments-table">
              <thead>
                <tr><th>Month</th><th>Group</th><th>Amount</th><th></th></tr>
              </thead>
              <tbody>
                <% charges.slice().reverse().forEach(function(c) { %>
                  <tr>
                    <td><%= c.month %></td>
                    <td><% const cg = studentGroups.find(function(g) { return g.id === c.groupId; }); %><%= cg ? cg.name : '--' %></td>
                    <td class="sv-pay-amount sv-charge-amount">&minus;<%= c.amount.toLocaleString() %> <%= currency %></td>
                    <td class="sv-pay-actions">
                      <form action="/students/charge/<%= student.id %>/delete/<%= c.id %>" method="POST" class="inline-form" onsubmit="return showDeleteModal(event, 'this charge')">
                        <button type="submit" class="sv-dropdown-item sv-dropdown-danger sv-charge-delete-btn">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <!-- Skip Month -->
        <div class="sv-payment-form-wrap sv-skip-month-wrap">
          <form id="skipMonthForm" action="/students/skip-month/<%= student.id %>" method="POST" class="sv-payment-form sv-skip-month-form">
            <input type="month" name="month" value="<%= new Date().toISOString().slice(0, 7) %>">
            <button type="button" class="sv-btn-outline sv-btn-warning" onclick="confirmSkipMonth()">Clear all charges for month</button>
          </form>
        </div>

        <!-- Payments Section -->
        <div class="sv-section-header" id="payment-section">
          <h2>Payments</h2>
        </div>
        <div class="sv-payment-form-wrap">
          <form action="/students/payment/<%= student.id %>" method="POST" class="sv-payment-form" id="paymentForm">
            <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>">
            <select name="status">
              <option value="paid">Payment</option>
              <option value="partial">Partial</option>
            </select>
            <input type="number" name="amount" step="0.01" min="0" placeholder="Amount" required>
            <input type="text" name="description" placeholder="Description">
            <button type="submit" class="sv-btn-outline sv-btn-teal" id="paymentSubmitBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add
            </button>
          </form>
        </div>

        <% if (payments.length > 0) { %>
          <div class="sv-payments-table-wrap" id="paymentsTableWrap">
            <table class="sv-payments-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Amount</th>
                  <th>Comment</th>
                  <th>Creator</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="paymentsTbody">
                <% payments.forEach(function(p) { %>
                  <tr>
                    <td class="sv-pay-date"><%= p.date %></td>
                    <td>
                      <span class="sv-pay-type-badge <%= p.status === 'paid' ? 'type-payment' : p.status === 'partial' ? 'type-partial' : 'type-system' %>">
                        <%= p.status === 'paid' ? 'payment' : p.status %>
                      </span>
                    </td>
                    <td class="sv-pay-amount <%= p.status === 'paid' || p.status === 'partial' ? 'positive' : '' %>">
                      <%= p.status === 'paid' || p.status === 'partial' ? '+' : '&minus;' %><%= (p.amount || 0).toLocaleString() %> <%= currency %>
                    </td>
                    <td class="sv-pay-comment">
                      <% if (studentGroups.length > 0) { %>
                        <span class="sv-comment-group-badge"><%= studentGroups[0].courseCode || studentGroups[0].name %></span>
                      <% } %>
                      <% if (p.description) { %>
                        <span class="sv-comment-detail"><%= p.description %></span>
                      <% } else if (p.status !== 'paid' && p.status !== 'partial' && studentGroups.length > 0) { %>
                        <span class="sv-comment-detail"><%= studentGroups[0].courseLessons || '' %> les.</span>
                        <% if (studentGroups[0].startDate) { %>
                          <div class="sv-comment-daterange"><%= studentGroups[0].startDate %>&mdash;<%= studentGroups[0].endDate || '' %></div>
                        <% } %>
                        <button class="sv-comment-more-btn">more</button>
                      <% } else { %>
                        <span class="sv-comment-detail">Cash</span>
                      <% } %>
                    </td>
                    <td class="sv-pay-creator">
                      <div class="sv-creator-name">Admin</div>
                      <div class="sv-creator-date"><%= p.date %></div>
                    </td>
                    <td class="sv-pay-actions">
                      <div class="sv-print-row">
                        <button class="sv-btn-outline sv-btn-teal sv-btn-small" onclick="window.print();">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                          Print out
                        </button>
                        <div class="sv-print-dropdown-wrap">
                          <button class="sv-btn-dropdown-sm" onclick="this.parentElement.classList.toggle('open');">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                          </button>
                          <div class="sv-print-dropdown">
                            <form action="/students/payment/<%= student.id %>/delete/<%= p.id %>" method="POST" class="inline-form" onsubmit="return showDeleteModal(event, 'this payment')">
                              <button type="submit" class="sv-dropdown-item sv-dropdown-danger">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                Delete
                              </button>
                            </form>
                          </div>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="sv-empty-payments" id="paymentsEmpty">
            <p class="muted" style="font-size:13px;">No payments recorded yet.</p>
          </div>
        <% } %>

        <div class="sv-section-header">
          <h2>Transaction Timeline</h2>
        </div>
        <% if ((transactions || []).length > 0) { %>
          <div class="sv-payments-table-wrap" id="transactionsTableWrap">
            <table class="sv-payments-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Amount</th>
                  <th>Label</th>
                </tr>
              </thead>
              <tbody id="transactionsTbody">
                <% transactions.forEach(function(t) { %>
                  <tr>
                    <td><%= t.date || '--' %></td>
                    <td><%= t.type %></td>
                    <td class="sv-pay-amount <%= t.type === 'payment' ? 'positive' : '' %>" style="<%= t.type === 'charge' ? 'color:var(--danger);' : '' %>">
                      <%= t.type === 'charge' ? '+' : '-' %><%= (t.amount || 0).toLocaleString() %> <%= currency %>
                    </td>
                    <td><%= t.label || '--' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="muted" style="font-size:13px;" id="transactionsEmpty">No transactions yet.</p>
        <% } %>
        </div>

        </div><!-- /stab-groups -->

        <!-- TAB: Comments (placeholder) -->
        <div class="sv-stab-content" id="stab-comments">
          <div class="sv-placeholder-panel">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <h3>Comments</h3>
            <p>Student comments and notes will appear here.</p>
          </div>
        </div>

        <!-- TAB: Call history (placeholder) -->
        <div class="sv-stab-content" id="stab-callhistory">
          <div class="sv-placeholder-panel">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <h3>Call history</h3>
            <p>Call logs will appear here.</p>
          </div>
        </div>

        <!-- TAB: SMS (placeholder) -->
        <div class="sv-stab-content" id="stab-sms">
          <div class="sv-placeholder-panel">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><line x1="9" y1="10" x2="15" y2="10"/></svg>
            <h3>SMS</h3>
            <p>SMS messages will appear here.</p>
          </div>
        </div>

        <!-- TAB: History (placeholder) -->
        <div class="sv-stab-content" id="stab-history">
          <div class="sv-placeholder-panel">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <h3>History</h3>
            <p>Student activity history will appear here.</p>
          </div>
        </div>

        <!-- TAB: Lead history (placeholder) -->
        <div class="sv-stab-content" id="stab-leadhistory">
          <div class="sv-placeholder-panel">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
            <h3>Lead history</h3>
            <p>Lead conversion history will appear here.</p>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- ============ EDIT STUDENT MODAL ============ -->
  <div class="sv-modal-overlay" id="editStudentModal" style="display:none;">
    <div class="sv-modal-container sv-edit-modal">
      <div class="sv-modal-header">
        <h2>Edit Student</h2>
        <button class="sv-modal-close" onclick="closeEditModal()">&times;</button>
      </div>
      <form id="editStudentForm" action="/students/edit/<%= student.id %>" method="POST" class="sv-modal-form">
        <div class="sv-form-group">
          <label for="editPhone">Phone</label>
          <div class="sv-phone-input-wrap">
            <span class="sv-phone-prefix">+998</span>
            <input type="tel" name="phone" id="editPhone" value="<%= (student.phone || '').replace('+998', '').replace(/^\s+/, '') %>" placeholder="XX XXX XX XX">
          </div>
        </div>
        <div class="sv-form-group">
          <label for="editName">Name</label>
          <input type="text" name="name" id="editName" value="<%= student.firstName %> <%= student.lastName %>">
        </div>
        <div class="sv-form-group">
          <label for="editBirthday">Date of birth</label>
          <div class="sv-date-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <input type="date" name="birthday" id="editBirthday" value="<%= student.birthday || '' %>">
          </div>
        </div>
        <div class="sv-form-group">
          <label>Gender</label>
          <div class="sv-gender-radios">
            <label class="sv-radio-label">
              <input type="radio" name="gender" value="male" <%= student.gender === 'male' ? 'checked' : '' %>>
              <span>Male</span>
            </label>
            <label class="sv-radio-label">
              <input type="radio" name="gender" value="female" <%= student.gender === 'female' ? 'checked' : '' %>>
              <span>Female</span>
            </label>
          </div>
        </div>
        <div class="sv-form-group">
          <label>Photo</label>
          <div class="sv-photo-input-wrap">
            <span class="sv-photo-label">No file chosen</span>
            <button type="button" class="sv-photo-browse-btn">Browse</button>
          </div>
        </div>
        <div class="sv-form-group">
          <label class="sv-contacts-label">additional contacts</label>
          <div class="sv-contact-icons">
            <button type="button" class="sv-contact-icon" style="background: #f59e0b;" title="Phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></button>
            <button type="button" class="sv-contact-icon" style="background: #22c55e;" title="WhatsApp"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg></button>
            <button type="button" class="sv-contact-icon" style="background: #ef4444;" title="Person"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></button>
            <button type="button" class="sv-contact-icon" style="background: #3b82f6;" title="Telegram"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></button>
            <button type="button" class="sv-contact-icon" style="background: #8b5cf6;" title="Email"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></button>
            <button type="button" class="sv-contact-icon" style="background: #ec4899;" title="Car"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></button>
            <button type="button" class="sv-contact-icon" style="background: #14b8a6;" title="Location"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></button>
            <button type="button" class="sv-contact-icon" style="background: #6366f1;" title="QR Code"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></button>
          </div>
        </div>
        <div class="sv-form-group">
          <label>Tags</label>
          <div class="sv-tags-input-wrap">
            <input type="text" placeholder="Add new tags" class="sv-tags-input">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="sv-tags-chevron"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
        <div class="sv-form-group">
          <a href="#" class="sv-set-password-link">+ Set password</a>
        </div>
        <button type="submit" class="sv-submit-btn">Submit</button>
      </form>
    </div>
  </div>

  <!-- ============ ADD TO GROUP MODAL ============ -->
  <div class="sv-modal-overlay" id="addToGroupModal" style="display:none;">
    <div class="sv-modal-container sv-add-group-modal">
      <div class="sv-modal-header">
        <h2>Add student to group</h2>
        <button class="sv-modal-close" onclick="closeAddToGroupModal()">&times;</button>
      </div>
      <form action="/students/add-to-group/<%= student.id %>" method="POST" class="sv-modal-form">
        <div class="sv-form-group">
          <select name="groupId" id="groupSelect" class="sv-group-select" onchange="updateGroupInfo()">
            <option value="">Select a group...</option>
            <% allGroups.forEach(function(g) { %>
              <%
                const gc = courses.find(c => c.id === g.courseId);
                const gt = teachers.find(t => t.id === g.teacherId);
                const gcName = gc ? gc.name : g.name;
                const gcCode = gc ? (gc.code || '') : '';
                const gtName = gt ? (gt.firstName + ' ' + gt.lastName) : '';
              %>
              <option value="<%= g.id %>" data-start="<%= g.startDate || '' %>" data-code="<%= gcCode %>" data-name="<%= gcName %>" data-teacher="<%= gtName %>" data-time="<%= g.startTime || '' %>">
                [<%= gcCode || gcName %>] <%= gcName %> (<%= gtName %> &middot; <%= g.startTime || '' %>)
              </option>
            <% }) %>
          </select>
        </div>
        <div class="sv-form-group" id="groupStartInfo" style="display:none;">
          <div class="sv-group-start-text">Group start date: <strong id="groupStartDate"></strong></div>
        </div>
        <div class="sv-form-group">
          <label>Date from</label>
          <div class="sv-date-input-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <input type="date" name="dateFrom" value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </div>
        <button type="submit" class="sv-add-group-btn">Add student to group</button>
      </form>
    </div>
  </div>

</main>

<script id="studentPageData" type="application/json"><%- JSON.stringify({
  payments: payments,
  transactions: (transactions || []).slice().reverse(),
  currency: currency,
  studentId: student.id,
  studentGroups: studentGroups.map(function(g) {
    return {
      id: g.id,
      name: g.name,
      courseCode: g.courseCode || '',
      courseLessons: g.courseLessons || '',
      startDate: g.startDate || '',
      endDate: g.endDate || ''
    };
  })
}) %></script>

<script>
  var state = {
    payments: [],
    transactions: [],
    currency: 'USD',
    studentId: '',
    studentGroups: []
  };

  (function initState() {
    var dataEl = document.getElementById('studentPageData');
    if (!dataEl) return;
    try {
      var parsed = JSON.parse(dataEl.textContent || '{}');
      state.payments = Array.isArray(parsed.payments) ? parsed.payments : [];
      state.transactions = Array.isArray(parsed.transactions) ? parsed.transactions : [];
      state.currency = parsed.currency || 'USD';
      state.studentId = parsed.studentId || '';
      state.studentGroups = Array.isArray(parsed.studentGroups) ? parsed.studentGroups : [];
    } catch (e) {
      state = state;
    }
  })();

  function fetchJson(url) {
    return fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(function(r) {
      if (!r.ok) throw new Error('Request failed');
      return r.json();
    });
  }

  function renderGroupsSection(groups) {
    var root = document.getElementById('studentGroupsSection');
    if (!root) return;
    if (!groups || !groups.length) {
      root.innerHTML = '<div class="sv-empty-groups"><p class="muted">No groups assigned. <a href="#" onclick="openAddToGroupModal(); return false;" style="color:var(--primary);">Add to a group</a></p></div>';
      return;
    }

    root.innerHTML = '<div class="sv-groups-row">' + groups.map(function(g) {
      return '' +
        '<div class="sv-group-card">' +
          '<div class="sv-group-main">' +
            '<div class="sv-group-top-row">' +
              '<div class="sv-group-left-info">' +
                '<span class="sv-group-code-badge">' + escapeHtml(g.courseCode || g.name || '') + '</span>' +
                '<div class="sv-group-name">' + escapeHtml(g.name || '') + '</div>' +
                '<div class="sv-group-teacher">' + escapeHtml(g.teacherName || '') + '</div>' +
              '</div>' +
              '<div class="sv-group-right-info">' +
                '<div class="sv-group-dates">' + escapeHtml(g.startDate || '') + ' &mdash;<br>' + escapeHtml(g.endDate || '') + '</div>' +
                '<div class="sv-group-schedule">' + escapeHtml(g.schedule || 'Other') + (g.scheduleTime ? (' &bull; ' + escapeHtml(g.scheduleTime)) : '') + '</div>' +
              '</div>' +
            '</div>' +
            '<div class="sv-group-divider"></div>' +
            '<div class="sv-group-details">' +
              '<div class="sv-group-detail-row"><span class="sv-detail-label">Status:</span><span class="sv-detail-value"><strong>Active (Learns)</strong></span></div>' +
              '<div class="sv-group-detail-row"><span class="sv-detail-label">Price for student:</span><span class="sv-detail-value"><strong>N/A</strong></span></div>' +
              '<div class="sv-group-detail-row"><span class="sv-detail-label">By group:</span><span class="sv-detail-value"><a href="/groups/view/' + escapeHtml(g.id || '') + '" class="sv-group-link-icon" title="View group">#</a></span></div>' +
            '</div>' +
          '</div>' +
        '</div>';
    }).join('') + '</div>';
  }

  function renderAttendanceSummary(data) {
    var root = document.getElementById('studentAttendanceSection');
    if (!root) return;
    var groups = (data && data.groups) ? data.groups : [];
    if (!groups.length) {
      root.innerHTML = '<p class="muted" style="font-size:13px;">No attendance data yet.</p>';
      return;
    }

    root.innerHTML =
      '<div class="sv-payments-table-wrap">' +
        '<table class="sv-payments-table">' +
          '<thead><tr><th>Group</th><th>Total</th><th>Present</th><th>Absent</th><th>Unmarked</th></tr></thead>' +
          '<tbody>' +
            groups.map(function(g) {
              return '<tr>' +
                '<td>' + escapeHtml(g.groupName || '--') + '</td>' +
                '<td>' + formatAmount(g.totalLessons || 0) + '</td>' +
                '<td style="color:var(--success);">' + formatAmount(g.present || 0) + '</td>' +
                '<td style="color:var(--danger);">' + formatAmount(g.absent || 0) + '</td>' +
                '<td>' + formatAmount(g.unmarked || 0) + '</td>' +
              '</tr>';
            }).join('') +
          '</tbody>' +
        '</table>' +
      '</div>';
  }

  function hydrateStudentInfo(info) {
    var nameEl = document.getElementById('svStudentName');
    var phoneEl = document.getElementById('svStudentPhone');
    var statusEl = document.getElementById('svStudentStatus');
    var noteEl = document.getElementById('svStudentNote');

    if (nameEl) nameEl.textContent = (info.firstName || '') + ' ' + (info.lastName || '');
    if (phoneEl) {
      phoneEl.textContent = info.phone || '';
      phoneEl.setAttribute('href', 'tel:' + (info.phone || ''));
    }
    if (statusEl) statusEl.textContent = String(info.status || 'active').toUpperCase();
    if (noteEl) noteEl.textContent = info.notes || 'Note';
  }

  // Edit Student Modal
  function openEditModal() {
    document.getElementById('editStudentModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeEditModal() {
    document.getElementById('editStudentModal').style.display = 'none';
    document.body.style.overflow = '';
  }

  // Student detail tabs
  document.querySelectorAll('.sv-tab[data-stab]').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.sv-tab[data-stab]').forEach(function(t) { t.classList.remove('active'); });
      document.querySelectorAll('.sv-stab-content').forEach(function(c) { c.classList.remove('active'); });
      tab.classList.add('active');
      var panel = document.getElementById('stab-' + tab.dataset.stab);
      if (panel) panel.classList.add('active');
    });
  });

  // Add to Group Modal
  function openAddToGroupModal() {
    document.getElementById('addToGroupModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeAddToGroupModal() {
    document.getElementById('addToGroupModal').style.display = 'none';
    document.body.style.overflow = '';
  }

  // Update group info when selection changes
  function updateGroupInfo() {
    var sel = document.getElementById('groupSelect');
    var opt = sel.options[sel.selectedIndex];
    var startDate = opt.getAttribute('data-start');
    var infoDiv = document.getElementById('groupStartInfo');
    var dateEl = document.getElementById('groupStartDate');
    if (startDate) {
      infoDiv.style.display = 'block';
      var d = new Date(startDate);
      dateEl.textContent = String(d.getDate()).padStart(2,'0') + '.' + String(d.getMonth()+1).padStart(2,'0') + '.' + d.getFullYear();
    } else {
      infoDiv.style.display = 'none';
    }
  }

  // Close modals on overlay click
  document.addEventListener('click', function(e) {
    if (e.target.id === 'editStudentModal') closeEditModal();
    if (e.target.id === 'addToGroupModal') closeAddToGroupModal();
  });

  // Close modals on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeEditModal();
      closeAddToGroupModal();
    }
  });

  // Close payment dropdown on outside click
  document.addEventListener('click', function(e) {
    var wrap = document.querySelector('.sv-payment-btn-wrap');
    if (wrap && !wrap.contains(e.target)) {
      wrap.classList.remove('open');
    }
  });

  // Skip Month confirmation
  function confirmSkipMonth() {
    var form = document.getElementById('skipMonthForm');
    var monthInput = form.querySelector('input[name="month"]');
    var month = monthInput ? monthInput.value : '';
    var overlay = document.createElement('div');
    overlay.className = 'modal-overlay';
    overlay.innerHTML =
      '<div class="modal-box">' +
        '<div class="modal-icon danger">' +
          '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>' +
        '</div>' +
        '<h3>Clear All Charges</h3>' +
        '<p>This will delete <strong>all charges</strong> for <strong>' + month + '</strong>. This cannot be undone.</p>' +
        '<div class="modal-actions">' +
          '<button class="btn btn-secondary" onclick="closeModal(this)">Cancel</button>' +
          '<button class="btn" onclick="doSkipMonth(this)" style="background:var(--warning);color:#fff;">Clear charges</button>' +
        '</div>' +
      '</div>';
    overlay._form = form;
    document.body.appendChild(overlay);
  }

  function doSkipMonth(btn) {
    var overlay = btn.closest('.modal-overlay');
    var form = overlay._form;
    overlay.classList.add('hiding');
    setTimeout(function() { overlay.remove(); }, 200);
    form.submit();
  }

  // Monthly balance scroll
  function scrollMonthly(dir) {
    var container = document.querySelector('.sv-monthly-cards');
    container.scrollBy({ left: dir * 200, behavior: 'smooth' });
  }

  function escapeHtml(str) {
    return String(str || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatAmount(num) {
    var n = Number(num || 0);
    return n.toLocaleString();
  }

  function renderPayments(appState) {
    var tableWrap = document.getElementById('paymentsTableWrap');
    var tbody = document.getElementById('paymentsTbody');
    var empty = document.getElementById('paymentsEmpty');
    if (!tableWrap || !tbody) return;

    if (!appState.payments.length) {
      tableWrap.style.display = 'none';
      if (empty) empty.style.display = '';
      return;
    }

    tableWrap.style.display = '';
    if (empty) empty.style.display = 'none';

    tbody.innerHTML = appState.payments.map(function(p) {
      var typeLabel = p.status === 'paid' ? 'payment' : p.status;
      var typeClass = p.status === 'paid' ? 'type-payment' : (p.status === 'partial' ? 'type-partial' : 'type-system');
      var detail = p.description ? escapeHtml(p.description) : 'Cash';
      var groupBadge = appState.studentGroups.length ? ('<span class="sv-comment-group-badge">' + escapeHtml(appState.studentGroups[0].courseCode || appState.studentGroups[0].name) + '</span>') : '';

      return '' +
        '<tr>' +
          '<td class="sv-pay-date">' + escapeHtml(p.date || '') + '</td>' +
          '<td><span class="sv-pay-type-badge ' + typeClass + '">' + escapeHtml(typeLabel) + '</span></td>' +
          '<td class="sv-pay-amount positive">+' + formatAmount(p.amount) + ' ' + escapeHtml(appState.currency) + '</td>' +
          '<td class="sv-pay-comment">' + groupBadge + '<span class="sv-comment-detail">' + detail + '</span></td>' +
          '<td class="sv-pay-creator"><div class="sv-creator-name">Admin</div><div class="sv-creator-date">' + escapeHtml(p.date || '') + '</div></td>' +
          '<td class="sv-pay-actions"><span class="muted" style="font-size:12px;">Saved</span></td>' +
        '</tr>';
    }).join('');
  }

  function renderTransactions(appState) {
    var tableWrap = document.getElementById('transactionsTableWrap');
    var tbody = document.getElementById('transactionsTbody');
    var empty = document.getElementById('transactionsEmpty');
    if (!tableWrap || !tbody) return;

    if (!appState.transactions.length) {
      tableWrap.style.display = 'none';
      if (empty) empty.style.display = '';
      return;
    }

    tableWrap.style.display = '';
    if (empty) empty.style.display = 'none';

    tbody.innerHTML = appState.transactions.map(function(t) {
      var isCharge = t.type === 'charge';
      return '' +
        '<tr>' +
          '<td>' + escapeHtml(t.date || '--') + '</td>' +
          '<td>' + escapeHtml(t.type || '') + '</td>' +
          '<td class="sv-pay-amount ' + (isCharge ? '' : 'positive') + '" style="' + (isCharge ? 'color:var(--danger);' : '') + '">' +
            (isCharge ? '+' : '-') + formatAmount(t.amount) + ' ' + escapeHtml(appState.currency) +
          '</td>' +
          '<td>' + escapeHtml(t.label || '--') + '</td>' +
        '</tr>';
    }).join('');
  }

  function render(appState) {
    renderPayments(appState);
    renderTransactions(appState);
  }

  // AJAX payment form + progressive section loading (hierarchy)
  document.addEventListener('DOMContentLoaded', function() {
    var studentId = state.studentId;
    var groupsSection = document.getElementById('studentGroupsSection');
    var attendanceSection = document.getElementById('studentAttendanceSection');
    var financeSection = document.getElementById('studentFinanceSection');

    // 1) show skeletons first
    if (groupsSection) {
      groupsSection.innerHTML =
        '<div class="skeleton skeleton-card" style="height:120px;margin-bottom:12px;"></div>' +
        '<div class="skeleton skeleton-card" style="height:120px;"></div>';
    }
    if (attendanceSection) {
      attendanceSection.innerHTML =
        '<div class="skeleton skeleton-text" style="height:18px;width:35%;margin-bottom:10px;"></div>' +
        '<div class="skeleton skeleton-text" style="height:14px;width:100%;"></div>' +
        '<div class="skeleton skeleton-text" style="height:14px;width:80%;"></div>';
    }
    if (financeSection) {
      financeSection.style.opacity = '0.55';
      financeSection.style.transition = 'opacity 220ms ease';
    }

    // 2) load sections one-by-one
    fetchJson('/api/students/' + studentId + '/info')
      .then(function(info) {
        hydrateStudentInfo(info);
        renderGroupsSection(info.groups || []);
        return fetchJson('/api/students/' + studentId + '/finance');
      })
      .then(function(finance) {
        state.currency = finance.currency || state.currency;
        state.payments = Array.isArray(finance.payments) ? finance.payments.slice().reverse() : [];
        state.transactions = Array.isArray(finance.transactions) ? finance.transactions.slice().reverse() : [];
        var balEl = document.getElementById('svStudentBalance');
        if (balEl) {
          var bal = Number(finance.balance || 0);
          balEl.textContent = formatAmount(bal) + ' ' + state.currency;
          balEl.className = 'sv-balance-pill ' + (bal < 0 ? 'negative' : bal > 0 ? 'positive' : 'zero');
        }
        render(state);
        if (financeSection) financeSection.style.opacity = '1';
        return fetchJson('/api/students/' + studentId + '/attendance');
      })
      .then(function(att) {
        renderAttendanceSummary(att);
      })
      .catch(function() {
        render(state);
        if (attendanceSection) {
          attendanceSection.innerHTML = '<p class="muted" style="font-size:13px;">Unable to load attendance summary right now.</p>';
        }
        if (financeSection) financeSection.style.opacity = '1';
      });

    var payForm = document.getElementById('paymentForm');
    var submitBtn = document.getElementById('paymentSubmitBtn');
    if (payForm) {
      payForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var form = this;
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.dataset.defaultText = submitBtn.textContent;
          submitBtn.textContent = 'Saving...';
        }
        var xhr = new XMLHttpRequest();
        xhr.open('POST', form.action, true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.onreadystatechange = function() {
          if (xhr.readyState === 4) {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = submitBtn.dataset.defaultText || 'Add';
            }
            if (xhr.status === 200) {
              var payload = {};
              try { payload = JSON.parse(xhr.responseText || '{}'); } catch (err) {}

              if (payload.payment) {
                state.payments.unshift(payload.payment);
              }
              if (payload.transaction) {
                state.transactions.unshift(payload.transaction);
              }

              render(state);
              form.reset();
              var dateInput = form.querySelector('input[name="date"]');
              if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];
              showToast('Payment added successfully', 'success');
            } else {
              showToast('Failed to add payment', 'error');
            }
          }
        };
        xhr.send(new URLSearchParams(new FormData(form)).toString());
      });
    }
  });
</script>
<%- include('../partials/footer') %>
