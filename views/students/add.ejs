<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <nav class="breadcrumb">
      <span class="breadcrumb-item"><a href="/">Dashboard</a></span>
      <span class="breadcrumb-item"><a href="/students">Students</a></span>
      <span class="breadcrumb-item active">Add</span>
    </nav>
    <div class="page-header">
      <h1>Add Student</h1>
      <a href="/students" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/students/add" method="POST" class="form-card">
      <div class="form-row">
        <%- include('../components/input', { id: 'firstName', label: 'First Name', name: 'firstName', required: true, placeholder: 'Enter first name' }) %>
        <%- include('../components/input', { id: 'lastName', label: 'Last Name', name: 'lastName', required: true, placeholder: 'Enter last name' }) %>
      </div>
      <div class="form-row">
        <%- include('../components/input', { id: 'phone', label: 'Phone Number', name: 'phone', required: true, placeholder: 'Enter phone number' }) %>
        <%- include('../components/input', { id: 'birthday', label: 'Birthday', name: 'birthday', type: 'date', required: false }) %>
      </div>
      <div class="form-group">
        <label for="groupId">Assign to Group</label>
        <% if (groups.length === 0) { %>
          <p class="muted">No groups available. <a href="/groups/add">Create a group first.</a></p>
        <% } else { %>
          <select id="groupId" name="groupId">
            <option value="">-- Select Group --</option>
            <% groups.forEach(g => { %>
              <option value="<%= g.id %>"><%= g.name %></option>
            <% }) %>
          </select>
        <% } %>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
            <option value="archived">Archived</option>
          </select>
        </div>
        <div class="form-group">
          <label for="notes">Notes</label>
          <input type="text" id="notes" name="notes" placeholder="Optional notes">
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Add Student</button>
        <a href="/students" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
