<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <nav class="breadcrumb">
      <span class="breadcrumb-item"><a href="/">Dashboard</a></span>
      <span class="breadcrumb-item"><a href="/students">Students</a></span>
      <span class="breadcrumb-item active">Edit</span>
    </nav>
    <div class="page-header">
      <h1>Edit Student</h1>
      <a href="/students" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/students/edit/<%= student.id %>" method="POST" class="form-card">
      <%- include('../components/input', { id: 'firstName', label: 'First Name', name: 'firstName', required: true, value: student.firstName }) %>
      <%- include('../components/input', { id: 'lastName', label: 'Last Name', name: 'lastName', required: true, value: student.lastName }) %>
      <%- include('../components/input', { id: 'phone', label: 'Phone Number', name: 'phone', type: 'tel', required: true, value: student.phone }) %>
      <div class="form-group">
        <label for="groupId">Assign to Group</label>
        <% if (groups.length === 0) { %>
          <p class="muted">No groups available.</p>
        <% } else { %>
          <select id="groupId" name="groupId">
            <option value="">-- None --</option>
            <% groups.forEach(g => { %>
              <option value="<%= g.id %>" <%= student.groupId === g.id || (student.groupIds || []).includes(g.id) ? 'selected' : '' %>><%= g.name %></option>
            <% }) %>
          </select>
        <% } %>
      </div>
      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status">
          <option value="active" <%= student.status === 'active' ? 'selected' : '' %>>Active</option>
          <option value="inactive" <%= student.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
          <option value="archived" <%= student.status === 'archived' ? 'selected' : '' %>>Archived</option>
        </select>
      </div>
      <div class="form-group">
        <label for="notes">Notes</label>
        <input type="text" id="notes" name="notes" value="<%= student.notes || '' %>">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/students" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
