<%- include('partials/head') %>
<%- include('partials/sidebar') %>
<main class="main-content">
  <%- include('partials/header') %>
  <div class="content-area">

    <!-- Stat Cards Row (Modme style) -->
    <div class="stats-grid">
      <a href="/leads" class="stat-card stat-card-link">
        <div class="stat-icon">
          <i data-lucide="download" width="36" height="36"></i>
        </div>
        <div class="stat-label">Active leads</div>
        <div class="stat-number"><%= activeLeadsCount %></div>
      </a>
      <a href="/students" class="stat-card stat-card-link">
        <div class="stat-icon">
          <i data-lucide="graduation-cap" width="36" height="36"></i>
        </div>
        <div class="stat-label">Active students</div>
        <div class="stat-number"><%= studentCount %></div>
      </a>
      <a href="/groups" class="stat-card stat-card-link">
        <div class="stat-icon">
          <i data-lucide="layers" width="36" height="36"></i>
        </div>
        <div class="stat-label">Groups</div>
        <div class="stat-number"><%= groupCount %></div>
      </a>
      <a href="/students?debt=unpaid" class="stat-card stat-card-link">
        <div class="stat-icon debtors">
          <i data-lucide="triangle-alert" width="36" height="36"></i>
        </div>
        <div class="stat-label">Debtors</div>
        <div class="stat-number danger"><%= debtorCount %></div>
      </a>
      <div class="stat-card">
        <div class="stat-icon">
          <i data-lucide="user-check" width="36" height="36"></i>
        </div>
        <div class="stat-label">In a trial lesson</div>
        <div class="stat-number"><%= trialLessonCount %></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">
          <i data-lucide="banknote" width="36" height="36"></i>
        </div>
        <div class="stat-label">Paid during the month</div>
        <div class="stat-number"><%= paidCount %></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">
          <i data-lucide="user-minus" width="36" height="36"></i>
        </div>
        <div class="stat-label">Left active group</div>
        <div class="stat-number"><%= leftActiveGroupCount %></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">
          <i data-lucide="user-x" width="36" height="36"></i>
        </div>
        <div class="stat-label">Left after trial period</div>
        <div class="stat-number"><%= leftAfterTrialCount %></div>
      </div>
    </div>

    <!-- Schedule Section -->
    <div class="dash-schedule-section">
      <div class="dash-schedule-header">
        <div class="dash-schedule-tabs">
          <button class="dash-tab" data-filter="odd">Odd days</button>
          <button class="dash-tab" data-filter="even">Even days</button>
          <button class="dash-tab active" data-filter="other">Other</button>
        </div>
        <h2 class="dash-schedule-title">Schedule</h2>
        <div class="dash-schedule-toggle">
          <span>Horizontal</span>
          <label class="toggle-switch">
            <input type="checkbox" id="scheduleOrientationToggle" checked>
            <span class="toggle-slider"></span>
          </label>
        </div>
      </div>

      <div class="dash-day-selector">
        <% var allDays = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun']; %>
        <% allDays.forEach(function(day) { %>
          <button class="dash-day-btn<%= day === todayDay ? ' active' : '' %>" data-day="<%= day %>"><%= day %>.</button>
        <% }) %>
      </div>

      <% if (scheduleRooms.length === 0 && todayGroups.length === 0) { %>
        <div class="empty-state" style="padding:40px;">
          <p>No groups scheduled. <a href="/groups/add" style="color:var(--primary);font-weight:600;">Add a group</a> with days and room to see the schedule.</p>
        </div>
      <% } else { %>
        <div class="schedule-table-wrap" id="dashScheduleTable">
          <table class="schedule-table schedule-horizontal">
            <thead>
              <tr>
                <th class="schedule-room-col"></th>
                <% scheduleTimeSlots.forEach(function(t) { %>
                  <th><%= t %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody>
              <% var colors = ['color-green','color-blue','color-pink','color-cyan','color-orange','color-purple']; %>
              <% var colorMap = {}; var colorIdx = 0; %>
              <% scheduleRooms.forEach(function(room) { %>
                <tr>
                  <td class="schedule-room-cell"><%= room %></td>
                  <% scheduleTimeSlots.forEach(function(t) { %>
                    <td class="schedule-cell">
                      <% var matches = todayGroups.filter(function(g) { return g.room === room && g.startTime === t; }); %>
                      <% matches.forEach(function(g) { %>
                        <% if (!colorMap[g.courseCode]) { colorMap[g.courseCode] = colors[colorIdx++ % colors.length]; } %>
                        <a href="/groups/view/<%= g.id %>" class="schedule-block <%= colorMap[g.courseCode] %>">
                          <% if (g.newDays !== null && g.newDays !== undefined) { %>
                            <span class="schedule-block-badge">new <%= g.newDays %> days</span>
                          <% } %>
                          <div class="schedule-block-top">
                            <span class="schedule-block-code"><%= g.courseCode %></span>
                            <span class="schedule-block-name"><%= g.name %></span>
                          </div>
                          <span class="schedule-block-teacher"><%= g.teacherName %></span>
                          <span class="schedule-block-meta"><%= g.dateRange %> · <%= g.daysStr %></span>
                          <span class="schedule-block-students"><%= g.studentCount %> st.<% if (g.maxStudents) { %> / <%= g.maxStudents %><% } %></span>
                        </a>
                      <% }) %>
                    </td>
                  <% }) %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</main>
<script>
// Day selector: client-side switching
(function(){
  var allDaysData = <%- allDaysGroups %>;
  var dayBtns = document.querySelectorAll('.dash-day-btn');
  dayBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      dayBtns.forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      // For full client-side day switch we'd rebuild the table.
      // For now, navigate with query param
      window.location.href = '/?day=' + btn.dataset.day;
    });
  });
})();
</script>
<%- include('partials/footer') %>
