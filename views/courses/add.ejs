<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <nav class="breadcrumb">
      <span class="breadcrumb-item"><a href="/">Dashboard</a></span>
      <span class="breadcrumb-item"><a href="/courses">Courses</a></span>
      <span class="breadcrumb-item active">Add</span>
    </nav>
    <div class="page-header">
      <h1>Add Course</h1>
      <a href="/courses" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/courses/add" method="POST" class="form-card">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Course Name</label>
          <input type="text" id="name" name="name" required placeholder="e.g. English A1, IELTS Prep">
        </div>
        <div class="form-group">
          <label for="code">Course Code</label>
          <input type="text" id="code" name="code" placeholder="e.g. ENG-A1, IELTS-01">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="lessonsPerMonth">Lessons per Month</label>
          <input type="number" id="lessonsPerMonth" name="lessonsPerMonth" min="0" placeholder="e.g. 12">
        </div>
        <div class="form-group">
          <label for="durationMinutes">Lesson Duration (minutes)</label>
          <input type="number" id="durationMinutes" name="durationMinutes" min="0" placeholder="e.g. 60">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="durationMonths">Course Duration (months)</label>
          <input type="number" id="durationMonths" name="durationMonths" min="0" placeholder="e.g. 6">
        </div>
        <div class="form-group">
          <label for="price">Price</label>
          <input type="number" id="price" name="price" step="0.01" min="0" placeholder="0.00">
        </div>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3" placeholder="Brief description of the course..."></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Add Course</button>
        <a href="/courses" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
