<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <nav class="breadcrumb">
      <span class="breadcrumb-item"><a href="/">Dashboard</a></span>
      <span class="breadcrumb-item"><a href="/courses">Courses</a></span>
      <span class="breadcrumb-item active">Edit</span>
    </nav>
    <div class="page-header">
      <h1>Edit Course</h1>
      <a href="/courses" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/courses/edit/<%= course.id %>" method="POST" class="form-card">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Course Name</label>
          <input type="text" id="name" name="name" required value="<%= course.name %>">
        </div>
        <div class="form-group">
          <label for="code">Course Code</label>
          <input type="text" id="code" name="code" value="<%= course.code || '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="lessonsPerMonth">Lessons per Module</label>
          <select id="lessonsPerMonth" name="lessonsPerMonth">
            <option value="0">-- Select --</option>
            <% for (let i = 1; i <= 28; i++) { %>
              <option value="<%= i %>" <%= course.lessonsPerMonth === i ? 'selected' : '' %>><%= i %></option>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label for="durationMinutes">Lesson Duration (minutes)</label>
          <select id="durationMinutes" name="durationMinutes">
            <option value="0">-- Select --</option>
            <% [30, 60, 90, 120, 150, 180, 210, 240, 270, 300].forEach(function(m) { %>
              <option value="<%= m %>" <%= course.durationMinutes === m ? 'selected' : '' %>><%= m %> min</option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="durationMonths">Course Duration (months)</label>
          <input type="number" id="durationMonths" name="durationMonths" min="1" max="36" value="<%= course.durationMonths || '' %>">
        </div>
        <div class="form-group">
          <label for="price">Price (per month)</label>
          <input type="number" id="price" name="price" step="0.01" min="0" value="<%= course.price || '' %>">
        </div>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3"><%= course.description || '' %></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/courses" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
