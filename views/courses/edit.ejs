<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>Edit Course</h1>
      <a href="/courses" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/courses/edit/<%= course.id %>" method="POST" class="form-card">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Course Name</label>
          <input type="text" id="name" name="name" required value="<%= course.name %>">
        </div>
        <div class="form-group">
          <label for="code">Course Code</label>
          <input type="text" id="code" name="code" value="<%= course.code || '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="lessonsPerMonth">Lessons per Month</label>
          <input type="number" id="lessonsPerMonth" name="lessonsPerMonth" min="0" value="<%= course.lessonsPerMonth || '' %>">
        </div>
        <div class="form-group">
          <label for="durationMinutes">Lesson Duration (minutes)</label>
          <input type="number" id="durationMinutes" name="durationMinutes" min="0" value="<%= course.durationMinutes || '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="durationMonths">Course Duration (months)</label>
          <input type="number" id="durationMonths" name="durationMonths" min="0" value="<%= course.durationMonths || '' %>">
        </div>
        <div class="form-group">
          <label for="price">Price</label>
          <input type="number" id="price" name="price" step="0.01" min="0" value="<%= course.price || '' %>">
        </div>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3"><%= course.description || '' %></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/courses" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
