<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<main class="main-content">
  <%- include('../partials/header') %>
  <div class="content-area">
    <div class="page-header">
      <h1>Courses <span class="page-subtitle">Quantity &mdash; <%= courses.length %></span></h1>
      <a href="/courses/add" class="btn btn-primary">ADD NEW</a>
    </div>

    <% if (search) { %>
      <p class="search-info">Search results for "<strong><%= search %></strong>" — <a href="/courses">Clear</a></p>
    <% } %>

    <% if (courses.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <p>No courses found.</p>
        <a href="/courses/add" class="btn btn-primary">Add your first course</a>
      </div>
    <% } else { %>
      <%
        var courseColors = ['#f97316', '#ec4899', '#14b8a6', '#eab308', '#8b5cf6', '#06b6d4', '#16a34a', '#2563eb'];
        var courseBgs = ['#fff7ed', '#fdf2f8', '#f0fdfa', '#fefce8', '#f5f3ff', '#ecfeff', '#f0fdf4', '#eff6ff'];
      %>
      <div class="courses-grid">
        <% courses.forEach((course, i) => { %>
          <% var color = courseColors[i % courseColors.length]; var bg = courseBgs[i % courseBgs.length]; %>
          <a href="/courses/view/<%= course.id %>" class="course-card" style="border-top:4px solid <%= color %>;">
            <div class="course-card-icon" style="background:<%= bg %>;color:<%= color %>;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <div class="course-card-name"><%= course.name %></div>
            <% if (course.code) { %>
              <div class="course-card-code"><%= course.code %></div>
            <% } %>
            <div class="course-card-price" style="color:<%= color %>;">
              <%= course.price ? course.price.toLocaleString() : '0' %>
            </div>
            <div class="course-card-meta">
              <% if (course.durationMonths) { %><span><%= course.durationMonths %> months</span><% } %>
              <% if (course.lessonsPerMonth) { %><span><%= course.lessonsPerMonth %> lessons/mo</span><% } %>
            </div>
            <div class="course-card-actions">
              <span class="btn btn-small btn-edit" onclick="event.preventDefault();window.location='/courses/edit/<%= course.id %>';">Edit</span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
